---
import "../styles/global.css";

type Props = {
  title: string;
};

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..700,0..100&family=IBM+Plex+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const preferredTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";

        try {
          document.documentElement.dataset.theme =
            localStorage.getItem("theme") || preferredTheme;
        } catch {
          document.documentElement.dataset.theme = preferredTheme;
        }
      })();
    </script>
  </head>
  <body>
    <slot />
    <script>
      const THEME_STORAGE_KEY = "theme";
      const DARK_THEME = "dark";
      const LIGHT_THEME = "light";

      const root = document.documentElement;
      const menuTrigger = document.querySelector("[data-menu-trigger]");
      const menuPanel = document.querySelector("[data-menu-panel]");

      function initializeThemeToggle() {
        const themeToggles = Array.from(document.querySelectorAll("[data-theme-toggle]"));
        const themeLabels = Array.from(document.querySelectorAll("[data-theme-label]"));

        if (themeToggles.length === 0) {
          return;
        }

        const setThemeToggleState = (theme: string) => {
          const isDark = theme === DARK_THEME;
          const label = isDark ? "Switch to light theme" : "Switch to dark theme";
          themeToggles.forEach((toggle) => {
            toggle.setAttribute("aria-pressed", String(isDark));
            toggle.setAttribute("aria-label", label);
            toggle.setAttribute("title", label);
          });
          themeLabels.forEach((themeLabel) => {
            themeLabel.textContent = isDark ? "Dark" : "Light";
          });
        };

        const applyTheme = (theme: string) => {
          root.dataset.theme = theme;
          setThemeToggleState(theme);
        };

        applyTheme(root.dataset.theme || LIGHT_THEME);

        themeToggles.forEach((toggle) => {
          toggle.addEventListener("click", () => {
            const nextTheme = root.dataset.theme === DARK_THEME ? LIGHT_THEME : DARK_THEME;
            try {
              localStorage.setItem(THEME_STORAGE_KEY, nextTheme);
            } catch {
              // Keep the current page interactive even when storage is unavailable.
            }
            applyTheme(nextTheme);
          });
        });
      }

      function initializeMobileMenu() {
        if (!menuTrigger || !menuPanel) {
          return;
        }

        document.body.append(menuPanel);
        const menuClose = menuPanel.querySelector("[data-menu-close]");

        const openMenu = () => {
          menuPanel.hidden = false;
          menuTrigger.setAttribute("aria-expanded", "true");
          document.body.dataset.menuOpen = "true";
          requestAnimationFrame(() => {
            menuPanel.setAttribute("data-open", "true");
            const firstTarget =
              menuPanel.querySelector<HTMLElement>(".mobile-menu-link.is-active") ??
              menuPanel.querySelector<HTMLElement>("a, button");
            firstTarget?.focus({ preventScroll: true });
          });
        };

        const closeMenu = () => {
          menuPanel.removeAttribute("data-open");
          menuTrigger.setAttribute("aria-expanded", "false");
          delete document.body.dataset.menuOpen;
          window.setTimeout(() => {
            if (!menuPanel.hasAttribute("data-open")) {
              menuPanel.hidden = true;
            }
          }, 180);
        };

        menuTrigger.addEventListener("click", () => {
          if (menuPanel.hidden) {
            openMenu();
            return;
          }

          closeMenu();
        });

        menuClose?.addEventListener("click", closeMenu);

        menuPanel.addEventListener("click", (event) => {
          if (event.target === menuPanel) {
            closeMenu();
          }
        });

        window.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && !menuPanel.hidden) {
            closeMenu();
            (menuTrigger as HTMLElement).focus({ preventScroll: true });
          }
        });
      }

      function initializeReadingProgress() {
        const progress = document.querySelector<HTMLElement>("[data-reading-progress]");
        const progressBar = document.querySelector<HTMLElement>("[data-reading-progress-bar]");
        const postBody = document.querySelector<HTMLElement>("[data-post-body]");

        if (!progress || !progressBar || !postBody) {
          return;
        }

        let frameId = 0;

        const clamp = (value: number) => Math.min(1, Math.max(0, value));

        const updateProgress = () => {
          frameId = 0;

          const bodyRect = postBody.getBoundingClientRect();
          const articleTop = bodyRect.top + window.scrollY;
          const readableDistance = Math.max(1, bodyRect.height - window.innerHeight);
          const progressValue = clamp((window.scrollY - articleTop) / readableDistance);

          progressBar.style.transform = `scaleX(${progressValue.toFixed(4)})`;
        };

        const requestProgressUpdate = () => {
          if (frameId) {
            return;
          }

          frameId = window.requestAnimationFrame(updateProgress);
        };

        updateProgress();
        window.addEventListener("scroll", requestProgressUpdate, { passive: true });
        window.addEventListener("resize", requestProgressUpdate);
      }

      initializeThemeToggle();
      initializeMobileMenu();
      initializeReadingProgress();
    </script>
  </body>
</html>
