---
import { getCollection } from "astro:content";
import DirectoryNav from "../components/DirectoryNav.astro";
import MobileDirectoryMenu from "../components/MobileDirectoryMenu.astro";
import PostCard from "../components/PostCard.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pageTitle } from "../../shared/seo/config";
import { breadcrumbSchema } from "../lib/seo-schemas";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const description =
  "Short pieces about projects, learning, readings, and the process of shaping this personal site over time.";
---

<BaseLayout
  title={pageTitle("Posts")}
  description={description}
  canonicalPath="/posts/"
  jsonLd={breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Posts", path: "/posts/" },
  ])}
>
  <main class="layout">
    <div class="page-shell">
      <DirectoryNav active="posts" />

      <article class="content-column project-detail">
        <header class="masthead">
          <a class="eyebrow masthead-home" href="/">Miguel Garcia • Posts</a>
          <div class="masthead-actions">
            <ThemeToggle />
            <MobileDirectoryMenu active="posts" />
          </div>
        </header>

        <section class="detail-hero">
          <h1>Notes and essays from the directory.</h1>
          <p class="lead">
            Short pieces about projects, learning, readings, and the process of shaping this personal site over time.
          </p>
        </section>

        <section class="detail-section" aria-labelledby="posts-title">
          <p class="section-label" id="posts-title">All posts</p>
          <ol class="reference-list">
            {posts.map((post) => <PostCard post={post} />)}
          </ol>
        </section>
      </article>
    </div>
  </main>
</BaseLayout>
