---
import { getCollection } from "astro:content";
import DirectoryNav from "../components/DirectoryNav.astro";
import MobileDirectoryMenu from "../components/MobileDirectoryMenu.astro";
import PostCard from "../components/PostCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Posts - Miguel Garcia">
  <main class="layout">
    <div class="page-shell">
      <DirectoryNav active="posts" />

      <article class="content-column project-detail">
        <header class="masthead">
          <a class="eyebrow masthead-home" href="/">Miguel Garcia • Posts</a>
          <div class="masthead-actions">
            <MobileDirectoryMenu active="posts" />
          </div>
        </header>

        <section class="detail-hero">
          <h1>Notes and essays from the directory.</h1>
          <p class="lead">
            Short pieces about projects, learning, readings, and the process of shaping this personal site over time.
          </p>
        </section>

        <section class="detail-section" aria-labelledby="posts-title">
          <p class="section-label" id="posts-title">All posts</p>
          <ol class="reference-list">
            {posts.map((post) => <PostCard post={post} />)}
          </ol>
        </section>
      </article>
    </div>
  </main>
</BaseLayout>
