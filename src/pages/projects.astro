---
import ProjectCard from "../components/ProjectCard.astro";
import DirectoryNav from "../components/DirectoryNav.astro";
import MobileDirectoryMenu from "../components/MobileDirectoryMenu.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
import { pageTitle } from "../../shared/seo/config";
import { breadcrumbSchema } from "../lib/seo-schemas";

const orderedProjects = [...projects].sort((a, b) => {
  if (a.featured !== b.featured) {
    return Number(b.featured) - Number(a.featured);
  }

  return b.year - a.year;
});

const description =
  "A selection of projects worth showing: things I have built, explored, learned from, or still think say something about how I work.";
---

<BaseLayout
  title={pageTitle("Projects")}
  description={description}
  canonicalPath="/projects/"
  jsonLd={breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Projects", path: "/projects/" },
  ])}
>
  <main class="layout">
    <div class="page-shell">
      <DirectoryNav active="projects" />

      <article class="content-column project-detail">
        <header class="masthead">
          <a class="eyebrow masthead-home" href="/">Miguel Garcia • Projects</a>
          <div class="masthead-actions">
            <ThemeToggle />
            <MobileDirectoryMenu active="projects" />
          </div>
        </header>

        <section class="detail-hero">
          <h1>Projects.</h1>
          <p class="lead">
            A selection of projects I find worth showing: things I have built, explored, learned from, or still think say something about how I work.
          </p>
        </section>

        <section class="detail-section" aria-labelledby="all-projects-title">
          <p class="section-label" id="all-projects-title">All projects</p>
          <ol class="project-list">
            {
              orderedProjects.map((project, index) => (
                <ProjectCard project={project} index={index} />
              ))
            }
          </ol>
        </section>
      </article>
    </div>
  </main>
</BaseLayout>
