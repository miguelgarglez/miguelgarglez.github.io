---
import ProjectCard from "../components/ProjectCard.astro";
import DirectoryNav from "../components/DirectoryNav.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
const orderedProjects = [...projects].sort((a, b) => {
  if (a.featured !== b.featured) {
    return Number(b.featured) - Number(a.featured);
  }

  return b.year - a.year;
});
---

<BaseLayout title="Projects - Miguel Garcia">
  <main class="layout">
    <div class="page-shell">
      <DirectoryNav active="projects" />

      <article class="content-column project-detail">
        <header class="masthead">
          <p class="eyebrow">Miguel Garcia • Projects</p>
          <a class="text-link" href="/">Back home</a>
        </header>

        <section class="detail-hero">
          <p class="section-label">Project Directory</p>
          <h1>Projects.</h1>
          <p class="lead">
            A selection of projects I find worth showing: things I have built, explored, learned from, or still think say something about how I work.
          </p>
        </section>

        <section class="detail-section" aria-labelledby="all-projects-title">
          <p class="section-label" id="all-projects-title">All projects</p>
          <ol class="project-list">
            {
              orderedProjects.map((project, index) => (
                <ProjectCard project={project} index={index} />
              ))
            }
          </ol>
        </section>
      </article>
    </div>
  </main>
</BaseLayout>
