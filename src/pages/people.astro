---
import BaseLayout from "../layouts/BaseLayout.astro";
import DirectoryNav from "../components/DirectoryNav.astro";
import MobileDirectoryMenu from "../components/MobileDirectoryMenu.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { people } from "../data/people";
import type { PersonArea } from "../data/people";
import { pageTitle } from "../../shared/seo/config";
import { breadcrumbSchema } from "../lib/seo-schemas";

const areaLabels: Record<PersonArea, string> = {
  design: "Design",
  engineering: "Engineering",
  education: "Education",
  product: "Product",
  "design-systems": "Design systems",
};

const groupedPeople = Object.entries(
  people.reduce(
    (groups, person) => {
      groups[person.area] = [...(groups[person.area] ?? []), person];
      return groups;
    },
    {} as Record<PersonArea, typeof people>,
  ),
) as Array<[PersonArea, typeof people]>;

const description =
  "A small map of designers, engineers, educators, and product-minded builders whose work helps me sharpen how I think and build.";
---

<BaseLayout
  title={pageTitle("People")}
  description={description}
  canonicalPath="/people/"
  jsonLd={breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "People", path: "/people/" },
  ])}
>
  <main class="layout">
    <div class="page-shell">
      <DirectoryNav active="people" />

      <article class="content-column project-detail">
        <header class="masthead">
          <a class="eyebrow masthead-home" href="/">Miguel Garcia • People</a>
          <div class="masthead-actions">
            <ThemeToggle />
            <MobileDirectoryMenu active="people" />
          </div>
        </header>

        <section class="detail-hero">
          <h1>People who shape my taste.</h1>
          <p class="lead">
            A small map of designers, engineers, educators, and product-minded builders whose work helps me sharpen how I think and build.
          </p>
        </section>

        {
          groupedPeople.map(([area, areaPeople]) => (
            <section class="detail-section" aria-labelledby={`${area}-title`}>
              <p class="section-label" id={`${area}-title`}>
                {areaLabels[area]}
              </p>
              <ol class="people-detail-list">
                {areaPeople.map((person) => (
                  <li class="people-detail-item">
                    <div>
                      <h2 class="reference-title">
                        <a href={person.href} target="_blank" rel="noopener noreferrer">
                          {person.name}
                        </a>
                      </h2>
                      <p class="reference-note">{person.summary}</p>
                    </div>
                    <ul class="detail-list">
                      {person.learns.map((lesson) => <li>{lesson}</li>)}
                    </ul>
                  </li>
                ))}
              </ol>
            </section>
          ))
        }
      </article>
    </div>
  </main>
</BaseLayout>
