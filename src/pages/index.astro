---
import ThemeToggle from "../components/ThemeToggle.astro";
import DirectoryNav from "../components/DirectoryNav.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const directoryLinks = [
  {
    href: "/projects",
    label: "Projects",
    note: "Software, products, and experiments.",
  },
  {
    href: "/readings",
    label: "Readings",
    note: "References that shape my judgment.",
  },
  {
    href: "/people",
    label: "People",
    note: "People I learn from.",
  },
  {
    href: "/posts",
    label: "Posts",
    note: "Short notes on engineering and process.",
  },
];

const socialLinks = [
  {
    href: "https://github.com/miguelgarglez",
    label: "GitHub",
  },
  {
    href: "https://www.linkedin.com/in/miguel-garciag",
    label: "LinkedIn",
  },
  {
    href: "https://x.com/miguel_garglez",
    label: "X",
  },
  {
    href: "/cv-chat",
    label: "CV Chat",
  },
];
---

<BaseLayout title="Miguel Garcia - Project Directory">
  <main class="layout home-layout">
    <div class="page-shell">
      <DirectoryNav active="home" label="Directory sections" />
      <div class="content-column home-content">
        <header class="masthead">
          <p class="eyebrow">Miguel Garcia • Directory</p>
          <ThemeToggle />
        </header>

        <section class="home-hero" aria-labelledby="directory-title">
          <p class="section-label">Personal directory</p>
          <h1 id="directory-title" class="home-title">Welcome.</h1>
          <div class="home-copy">
            <p>
              I'm Miguel Garcia, a software engineer based in Madrid.
            </p>
            <p>
              I care about technical quality, product clarity, and the small details
              that make software easier to use. This directory collects projects,
              notes, readings, and references around that way of working.
            </p>
            <p>
              If you want the professional version of the story, start with
              <a href="/cv-chat">CV Chat</a>. Otherwise, explore the sections below.
            </p>
          </div>

          <nav class="home-link-grid" aria-label="Directory areas">
            {
              directoryLinks.map((link) => (
                <a href={link.href} class="home-link-card">
                  <span>{link.label}</span>
                  <small>{link.note}</small>
                </a>
              ))
            }
          </nav>

          <div class="home-socials" aria-label="External links">
            {
              socialLinks.map((link) => (
                <a
                  href={link.href}
                  target={link.href.startsWith("http") ? "_blank" : undefined}
                  rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                >
                  {link.label}
                </a>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
