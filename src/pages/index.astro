---
import ProjectCard from "../components/ProjectCard.astro";
import PersonReference from "../components/PersonReference.astro";
import ReadingCard from "../components/ReadingCard.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import DirectoryNav from "../components/DirectoryNav.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { people } from "../data/people";
import { projects } from "../data/projects";
import { readings } from "../data/readings";

const featuredProjects = projects.filter((project) => project.featured).slice(0, 3);
const featuredReadings = readings.filter((reading) => reading.featured).slice(0, 3);
const featuredPeople = people.filter((person) => person.featured).slice(0, 3);
---

<BaseLayout title="Miguel Garcia - Project Directory">
  <main class="layout">
    <div class="page-shell">
      <DirectoryNav active="home" label="Directory sections" />
      <div class="content-column">
        <header class="masthead">
          <p class="eyebrow">Miguel Garcia • Directory</p>
          <ThemeToggle />
        </header>

        <section
          class="intro"
          id="overview"
          data-section-anchor
          aria-labelledby="directory-title"
        >
          <h1 id="directory-title">An index of projects, people, and ideas.</h1>
          <p class="lead">
            A directory of things I build and the work that inspires them.
          </p>
        </section>

        <section id="projects" data-section-anchor aria-labelledby="projects-title">
          <div class="section-heading">
            <p class="section-label" id="projects-title">Projects</p>
            <a class="text-link" href="/projects">View all projects</a>
          </div>
          <ol class="project-list">
            {
              featuredProjects.map((project, index) => (
                <ProjectCard project={project} index={index} />
              ))
            }
          </ol>
        </section>

        <section id="readings" data-section-anchor aria-labelledby="readings-title">
          <div class="section-heading">
            <p class="section-label" id="readings-title">Readings</p>
            <a class="text-link" href="/readings">View all readings</a>
          </div>
          <ol class="reference-list">
            {featuredReadings.map((reading) => <ReadingCard reading={reading} />)}
          </ol>
        </section>

        <section
          id="inspiring-people"
          data-section-anchor
          aria-labelledby="inspiring-people-title"
        >
          <div class="section-heading">
            <p class="section-label" id="inspiring-people-title">Inspiring people</p>
            <a class="text-link" href="/people">View all people</a>
          </div>
          <ol class="reference-list">
            {featuredPeople.map((person) => <PersonReference person={person} />)}
          </ol>
        </section>

        <footer>
          <p class="footer-note">Last update: April 2026.</p>
        </footer>
      </div>
    </div>
  </main>

  <script>
    const SIDEBAR_SCROLL_THRESHOLD = 36;

    const sidebar = document.querySelector("[data-sidebar]");

    function initializeSidebarFade() {
      if (!sidebar) {
        return;
      }

      const syncSidebarOpacity = () => {
        sidebar.classList.toggle("is-scrolled", window.scrollY > SIDEBAR_SCROLL_THRESHOLD);
      };

      syncSidebarOpacity();
      window.addEventListener("scroll", syncSidebarOpacity, {
        passive: true,
      });
    }

    initializeSidebarFade();
  </script>
</BaseLayout>
