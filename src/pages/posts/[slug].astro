---
import { getCollection, render, type CollectionEntry } from "astro:content";
import DirectoryNav from "../../components/DirectoryNav.astro";
import MobileDirectoryMenu from "../../components/MobileDirectoryMenu.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatReadingTime } from "../../lib/reading-time.js";
import { pageTitle } from "../../../shared/seo/config";
import { blogPostingSchema, breadcrumbSchema } from "../../lib/seo-schemas";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<"posts">;
};

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = post.data.date.toLocaleDateString("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
const readingTime = formatReadingTime(post.body ?? "");
const ogImage = `/og/posts/${post.id}.png`;
---

<BaseLayout
  title={pageTitle(post.data.title, { suffix: false })}
  description={post.data.description}
  canonicalPath={`/posts/${post.id}/`}
  image={ogImage}
  imageAlt={`${post.data.title} — Miguel García`}
  type="article"
  publishedTime={post.data.date.toISOString()}
  modifiedTime={(post.data.updatedDate ?? post.data.date).toISOString()}
  tags={post.data.tags}
  jsonLd={[
    blogPostingSchema({
      title: post.data.title,
      description: post.data.description,
      slug: post.id,
      date: post.data.date,
      updatedDate: post.data.updatedDate,
      tags: post.data.tags,
    }),
    breadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Posts", path: "/posts/" },
      { name: post.data.title, path: `/posts/${post.id}/` },
    ]),
  ]}
>
  <div class="reading-progress" data-reading-progress aria-hidden="true">
    <span class="reading-progress-bar" data-reading-progress-bar></span>
  </div>

  <main class="layout">
    <div class="page-shell">
      <DirectoryNav active="posts" />

      <article class="content-column project-detail">
        <header class="masthead">
          <a class="eyebrow masthead-home" href="/">Miguel Garcia • Posts</a>
          <div class="masthead-actions">
            <ThemeToggle />
            <MobileDirectoryMenu active="posts" />
          </div>
        </header>

        <section class="detail-hero post-hero">
          <h1>{post.data.title}</h1>
          <p class="lead">{post.data.description}</p>
          <ul class="post-meta" aria-label="Post metadata">
            <li>{formattedDate}</li>
            <li>{readingTime}</li>
            <li>{post.data.kind}</li>
          </ul>
          <ul class="stack" aria-label="Post tags">
            {post.data.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </section>

        <section class="detail-section">
          <div class="post-body" data-post-body>
            <Content />
          </div>
        </section>
      </article>
    </div>
  </main>
</BaseLayout>
