---
import { Icon } from 'astro-icon/components';
---

<!-- ThemeToggle.astro -->
<button id="theme-toggle" type="button" aria-label="Switch theme">
  <span class="sun-icon" aria-hidden="true">
    <Icon name="lucide:sun" aria-hidden="true" />
  </span>
  <span class="moon-icon" aria-hidden="true">
    <Icon name="lucide:moon" aria-hidden="true" />
  </span>
</button>

<script>
  const themeToggle = document.getElementById('theme-toggle');

  themeToggle?.addEventListener('click', () => {
    const nextTheme = document.body.classList.contains('light')
      ? 'dark'
      : 'light';

    if (typeof window['__setPreferredTheme'] === 'function') {
      window['__setPreferredTheme'](nextTheme);
    } else {
      document.body.classList.toggle('light', nextTheme === 'light');
    }
  });
</script>

<style>
  #theme-toggle {
    --focus-radius: 999px;
    background: none;
    border: none;
    cursor: pointer;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    transition:
      transform 180ms ease,
      color 180ms ease;
    color: var(--text);
    display: grid;
    place-items: center;
  }

  #theme-toggle:hover {
    transform: scale(1.08);
    color: var(--primary);
  }

  #theme-toggle:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px var(--focus-ring-soft);
  }

  .sun-icon,
  .moon-icon {
    display: none;
  }

  .sun-icon svg,
  .moon-icon svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  body.light .moon-icon {
    display: inline;
  }

  body:not(.light) .sun-icon {
    display: inline;
  }

  body:not(.light) #theme-toggle {
    color: color-mix(in srgb, var(--primary) 88%, white 12%);
  }

  @media (max-width: 640px) {
    #theme-toggle {
      width: 2rem;
      height: 2rem;
    }

    #theme-toggle svg {
      width: 1.2rem;
      height: 1.2rem;
    }
  }
</style>
