---
import { Icon } from 'astro-icon/components';
---

<!-- ThemeToggle.astro -->
<button id="theme-toggle" type="button" aria-label="Switch theme">
  <span class="sun-icon" aria-hidden="true">
    <Icon name="lucide:sun" aria-hidden="true" />
  </span>
  <span class="moon-icon" aria-hidden="true">
    <Icon name="lucide:moon" aria-hidden="true" />
  </span>
</button>

<script>
  const themeToggle = document.getElementById('theme-toggle');

  themeToggle?.addEventListener('click', () => {
    const nextTheme = document.body.classList.contains('light')
      ? 'dark'
      : 'light';

    if (typeof window['__setPreferredTheme'] === 'function') {
      window['__setPreferredTheme'](nextTheme);
    } else {
      document.body.classList.toggle('light', nextTheme === 'light');
    }
  });
</script>

<style>
  #theme-toggle {
    position: fixed;
    top: calc(var(--safe-area-top) + 16px);
    right: calc(var(--safe-area-right) + 16px);
    background: none;
    border: none;
    cursor: pointer;
    font-size: 24px;
    width: 44px;
    height: 44px;
    z-index: 9999;
    padding: 0;
    border-radius: 999px;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease;
    color: var(--text);
    display: grid;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--border) 90%, transparent);
    background: color-mix(in srgb, var(--bg-light) 78%, transparent);
    backdrop-filter: blur(14px);
    box-shadow: var(--shadow-card);
  }

  #theme-toggle:hover {
    transform: scale(1.08);
    border-color: color-mix(in srgb, var(--primary) 40%, var(--border));
    color: var(--primary);
  }

  #theme-toggle:focus-visible {
    outline: none;
    box-shadow:
      var(--shadow-card),
      0 0 0 3px color-mix(in srgb, var(--primary) 24%, transparent);
  }

  .sun-icon,
  .moon-icon {
    display: none;
  }

  .sun-icon svg,
  .moon-icon svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  body.light .moon-icon {
    display: inline;
  }

  body:not(.light) .sun-icon {
    display: inline;
  }

  body:not(.light) #theme-toggle {
    color: color-mix(in srgb, var(--primary) 88%, white 12%);
  }
</style>
