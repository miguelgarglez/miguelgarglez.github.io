---
import { Icon } from "astro-icon/components";
import AsciiField from "./AsciiField.astro";
---

<script is:inline>
    document.documentElement.classList.add("js");
</script>

<section class="hero" aria-labelledby="hero-name">
    <div class="hero-shell">
        <div class="page-shell hero-stage">
            <div class="hero-content">
                <div class="hero-copy">
                    <h1
                        id="hero-name"
                        class="hero-name"
                        data-hero-entrance="name"
                    >
                        Miguel García
                    </h1>
                    <p class="hero-summary" data-hero-entrance="summary">
                        Frontend platform engineer building design systems and
                        practical AI workflows.
                    </p>

                    <div class="hero-meta" aria-label="Profile metadata">
                        <span data-hero-entrance="meta">
                            <span class="hero-meta-index">01</span>
                            <span class="hero-meta-label">location</span>
                            <span class="hero-meta-value">Madrid</span>
                        </span>
                        <span data-hero-entrance="meta">
                            <span class="hero-meta-index">02</span>
                            <span class="hero-meta-label">currently</span>
                            <span class="hero-meta-value"
                                >Frontend Platform</span
                            >
                        </span>
                        <span data-hero-entrance="meta">
                            <span class="hero-meta-index">03</span>
                            <span class="hero-meta-label">craft</span>
                            <span class="hero-meta-value">Interface Systems</span>
                        </span>
                        <span data-hero-entrance="meta">
                            <span class="hero-meta-index">04</span>
                            <span class="hero-meta-label">ai</span>
                            <span class="hero-meta-value">Applied</span>
                        </span>
                    </div>
                </div>

                <AsciiField />
            </div>
        </div>

        <a class="hero-scroll" href="#about" aria-label="Scroll to About">
            <span class="hero-scroll-label" data-hero-entrance="scroll-label"
                >See more</span
            >
            <Icon
                name="lucide:chevron-down"
                aria-hidden="true"
                data-hero-entrance="scroll-arrow"
            />
        </a>
    </div>
</section>

<script>
    import { getMotionTools, prefersReducedMotion } from "../../lib/motion";

    document.addEventListener("DOMContentLoaded", async () => {
        const about = document.querySelector("#about");
        const heroScroll = document.querySelector(".hero-scroll");

        if (heroScroll && about) {
            let frame = 0;

            const syncHeroScroll = () => {
                frame = 0;
                const aboutTop = about.getBoundingClientRect().top;
                const hasReachedAbout = aboutTop <= window.innerHeight * 0.82;

                heroScroll.toggleAttribute("data-hidden", hasReachedAbout);
            };

            const scheduleSync = () => {
                if (frame) return;
                frame = window.requestAnimationFrame(syncHeroScroll);
            };

            syncHeroScroll();
            window.addEventListener("scroll", scheduleSync, { passive: true });
            window.addEventListener("resize", scheduleSync, { passive: true });
            window.addEventListener("orientationchange", scheduleSync, {
                passive: true,
            });
        }

        if (prefersReducedMotion()) {
            document
                .querySelectorAll("[data-hero-entrance]")
                .forEach((element) => element.removeAttribute("style"));
            return;
        }

        const { gsap } = await getMotionTools();

        /*
         * HERO ENTRANCE STORYBOARD
         *
         * Read top-to-bottom. Each value is seconds after the timeline starts.
         *
         * 0.18s   name lands with authority: opacity 0 -> 1, y 18 -> 0
         * 0.36s   summary follows softer: opacity 0 -> 1, y 12 -> 0
         * 0.52s   metadata rows draw in with a short technical stagger
         * 0.82s   scroll label appears
         * 0.96s   scroll arrow settles into place
         *
         * The ASCII field owns its character-level intro wave internally.
         */
        const TIMING = {
            name: 0.18,
            summary: 0.36,
            meta: 0.52,
            scrollLabel: 0.82,
            scrollArrow: 0.96,
        };

        const MOTION = {
            enterEase: "power4.out",
            settleEase: "back.out(1.18)",
            name: {
                y: 18,
                duration: 0.72,
            },
            summary: {
                y: 12,
                duration: 0.52,
            },
            meta: {
                y: 10,
                duration: 0.46,
                stagger: 0.055,
            },
            scrollLabel: {
                y: 8,
                duration: 0.34,
            },
            scrollArrow: {
                y: -4,
                duration: 0.38,
            },
        };

        gsap.set("[data-hero-entrance='name']", {
            y: MOTION.name.y,
            opacity: 0,
        });
        gsap.set("[data-hero-entrance='summary']", {
            y: MOTION.summary.y,
            opacity: 0,
        });
        gsap.set("[data-hero-entrance='meta']", {
            y: MOTION.meta.y,
            opacity: 0,
        });
        gsap.set("[data-hero-entrance='scroll-label']", {
            y: MOTION.scrollLabel.y,
            opacity: 0,
        });
        gsap.set(".hero-scroll svg", {
            y: MOTION.scrollArrow.y,
            opacity: 0,
        });

        const tl = gsap.timeline({ defaults: { ease: MOTION.enterEase } });

        tl.to(
            "[data-hero-entrance='name']",
            {
                y: 0,
                opacity: 1,
                duration: MOTION.name.duration,
            },
            TIMING.name,
        )
            .to(
                "[data-hero-entrance='summary']",
                {
                    y: 0,
                    opacity: 1,
                    duration: MOTION.summary.duration,
                },
                TIMING.summary,
            )
            .to(
                "[data-hero-entrance='meta']",
                {
                    y: 0,
                    opacity: 1,
                    duration: MOTION.meta.duration,
                    stagger: MOTION.meta.stagger,
                },
                TIMING.meta,
            )
            .to(
                "[data-hero-entrance='scroll-label']",
                {
                    y: 0,
                    opacity: 1,
                    duration: MOTION.scrollLabel.duration,
                },
                TIMING.scrollLabel,
            )
            .to(
                ".hero-scroll svg",
                {
                    y: 0,
                    opacity: 1,
                    duration: MOTION.scrollArrow.duration,
                    ease: MOTION.settleEase,
                },
                TIMING.scrollArrow,
            );
    });
</script>

<style>
    .hero {
        position: relative;
        min-height: 100svh;
        overflow: clip;
    }

    :global(.js) .hero [data-hero-entrance] {
        opacity: 0;
    }

    @media (prefers-reduced-motion: reduce) {
        :global(.js) .hero [data-hero-entrance] {
            opacity: 1;
        }
    }

    .hero-shell {
        position: relative;
        z-index: 1;
        padding-top: 0.5rem;
        min-height: 100svh;
    }

    .hero-stage {
        width: 100%;
    }

    .hero-content {
        --hero-padding-top: 2.5rem;
        --hero-padding-inline: 0;
        --hero-padding-bottom: 2rem;

        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);
        grid-template-rows: 1fr auto;
        gap: clamp(1.5rem, 3vw, 3rem);
        align-items: stretch;
        align-content: stretch;
        min-height: calc(100svh - 4.75rem);
        padding: var(--hero-padding-top) var(--hero-padding-inline)
            var(--hero-padding-bottom);
    }

    .hero-copy {
        grid-column: 1;
        grid-row: 2;
        max-width: 40rem;
        display: grid;
        gap: 1rem;
        align-self: end;
    }

    .hero-content :global(.ascii-field) {
        grid-column: 2;
        grid-row: 1 / span 2;
        align-self: stretch;
    }

    .hero-name {
        margin: 0;
        color: var(--text);
        font-family: var(--font-display);
        font-size: clamp(2.95rem, 8vw, 6.7rem);
        line-height: 0.92;
        letter-spacing: -0.06em;
        text-wrap: nowrap;
        white-space: nowrap;
    }

    .hero-summary {
        margin: 0;
        max-width: 28rem;
        color: var(--text-muted);
        font-size: clamp(1.05rem, 2vw, 1.2rem);
        line-height: 1.75;
    }

    .hero-meta {
        display: grid;
        grid-template-columns: minmax(8.5rem, 0.72fr) minmax(11rem, 1fr);
        gap: 0.72rem clamp(0.95rem, 2vw, 1.45rem);
        max-width: 34rem;
        padding-top: 0.2rem;
    }

    .hero-meta > span {
        position: relative;
        display: grid;
        grid-template-columns: auto 1fr;
        grid-template-areas:
            "index label"
            "index value";
        column-gap: 0.55rem;
        row-gap: 0.05rem;
        min-width: 0;
        border-top: 1px solid color-mix(in srgb, var(--border) 76%, transparent);
        padding-top: 0.62rem;
        color: var(--text);
        font-family: var(--font-mono);
        letter-spacing: 0;
    }

    .hero-meta > span:nth-child(even) {
        transform: translateY(0.45rem);
    }

    .hero-meta > span::before {
        content: "";
        position: absolute;
        top: -1px;
        left: 0;
        width: clamp(1.7rem, 34%, 4rem);
        height: 1px;
        background: var(--primary);
        box-shadow: 0 0 16px color-mix(in srgb, var(--primary) 32%, transparent);
    }

    .hero-meta-index {
        grid-area: index;
        align-self: start;
        color: color-mix(in srgb, var(--primary) 86%, var(--text));
        font-size: 0.72rem;
        line-height: 1.1;
    }

    .hero-meta-label {
        grid-area: label;
        color: var(--text-subtle);
        font-size: 0.58rem;
        line-height: 1;
        text-transform: uppercase;
    }

    .hero-meta-value {
        grid-area: value;
        overflow: hidden;
        color: color-mix(in srgb, var(--text) 92%, var(--primary));
        font-size: 0.79rem;
        line-height: 1.25;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .hero-meta > span:nth-child(1),
    .hero-meta > span:nth-child(4) {
        max-width: 13rem;
    }

    .hero-scroll {
        position: fixed;
        left: 50%;
        bottom: max(
            clamp(1.5rem, 4vh, 3rem),
            calc(var(--safe-area-bottom) + 1rem)
        );
        transform: translateX(-50%);
        display: grid;
        place-items: center;
        gap: 0.45rem;
        min-width: 5rem;
        width: max-content;
        color: var(--text);
        text-decoration: none;
        z-index: 5;
        transition: opacity 220ms var(--ease-out-quart);
        animation: scroll-bob 2.2s var(--ease-out-expo) infinite;
    }

    .hero-scroll[data-hidden] {
        opacity: 0 !important;
        pointer-events: none;
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-scroll {
            animation: none;
        }
    }

    .hero-scroll-label {
        font-family: var(--font-mono);
        font-size: 0.95rem;
        letter-spacing: 0.02em;
    }

    .hero-scroll svg {
        width: 3rem;
        height: 3rem;
    }

    @keyframes scroll-bob {
        0%,
        100% {
            transform: translateX(-50%) translateY(0);
        }
        50% {
            transform: translateX(-50%) translateY(7px);
        }
    }

    @media (max-width: 900px) {
        .hero-content {
            --hero-padding-top: 2rem;
            --hero-padding-bottom: 3.5rem;

            grid-template-columns: 1fr;
            grid-template-rows: minmax(0, 1fr) minmax(0, auto);
            grid-template-areas:
                "ascii"
                "copy";
            align-items: start;
            align-content: end;
            min-height: calc(100svh - 4.75rem);
            gap: 1.6rem;
        }

        .hero-copy,
        .hero-content :global(.ascii-field) {
            grid-column: auto;
            grid-row: auto;
        }

        .hero-copy {
            grid-area: copy;
        }

        .hero-content :global(.ascii-field) {
            grid-area: ascii;
        }
    }

    @media (max-width: 640px) {
        .hero-name {
            font-size: clamp(2.6rem, 10.8vw, 4.35rem);
        }

        .hero-meta > span {
            max-width: 100%;
        }

        .hero-content {
            --hero-padding-top: 1.25rem;
            --hero-padding-bottom: 2.5rem;
            gap: clamp(1rem, 3svh, 1.55rem);
        }

        .hero-copy {
            gap: 0.9rem;
        }

        .hero-scroll {
            bottom: calc(var(--safe-area-bottom) + 1rem);
            width: max-content;
            max-width: calc(100vw - 2rem);
            padding-inline: 0.5rem;
            gap: 0.35rem;
        }

        .hero-scroll-label {
            font-size: 0.82rem;
        }
    }

    @media (max-width: 430px) {
        .hero-meta {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.72rem 0.78rem;
        }

        .hero-meta > span {
            min-width: 0;
            padding-top: 0.52rem;
            letter-spacing: 0;
        }

        .hero-meta-index {
            font-size: 0.66rem;
        }

        .hero-meta-label {
            font-size: 0.52rem;
        }

        .hero-meta-value {
            font-size: 0.68rem;
        }
    }

    @media (max-height: 650px) {
        .hero-scroll {
            display: none;
        }
    }

    @media (min-width: 901px) and (max-height: 860px) {
        .hero-content {
            --hero-padding-top: 1.4rem;
            --hero-padding-bottom: 1.35rem;

            min-height: calc(100svh - 4rem);
            gap: clamp(1rem, 2vw, 2rem);
        }

        .hero-copy {
            max-width: 38rem;
            gap: 0.72rem;
            transform: translateY(-1.1rem);
        }

        .hero-name {
            font-size: clamp(2.95rem, 7vw, 5.75rem);
        }

        .hero-summary {
            font-size: clamp(1rem, 1.6vw, 1.08rem);
            line-height: 1.55;
        }

        .hero-meta {
            gap: 0.52rem clamp(0.9rem, 1.8vw, 1.2rem);
            max-width: 32rem;
            padding-top: 0.05rem;
        }

        .hero-meta > span {
            padding-top: 0.46rem;
        }

        .hero-meta > span:nth-child(even) {
            transform: translateY(0.28rem);
        }

        .hero-meta-index {
            font-size: 0.66rem;
        }

        .hero-meta-label {
            font-size: 0.52rem;
        }

        .hero-meta-value {
            font-size: 0.72rem;
        }

        .hero-scroll {
            bottom: calc(var(--safe-area-bottom) + 0.75rem);
            gap: 0.25rem;
        }

        .hero-scroll-label {
            font-size: 0.82rem;
        }

        .hero-scroll svg {
            width: 2.35rem;
            height: 2.35rem;
        }
    }

    @media (max-width: 350px) and (max-height: 775px) {
        .hero-shell {
            padding-top: 0;
        }

        .hero-content {
            --hero-padding-top: 4.25rem;
            --hero-padding-bottom: 5.25rem;
            min-height: 100svh;
            grid-template-rows: minmax(0, 1fr) auto;
            align-content: stretch;
            gap: clamp(1.25rem, 3svh, 1.85rem);
        }

        .hero-content :global(.ascii-field) {
            align-self: center;
        }

        .hero-copy {
            gap: 0.7rem;
        }

        .hero-summary {
            font-size: 0.94rem;
            line-height: 1.48;
        }

        .hero-meta {
            grid-template-columns: minmax(0, 0.86fr) minmax(0, 1fr);
            gap: 0.62rem 0.68rem;
        }

        .hero-meta > span {
            padding-top: 0.45rem;
        }

        .hero-meta-index {
            font-size: 0.58rem;
        }

        .hero-meta-label {
            font-size: 0.48rem;
        }

        .hero-meta-value {
            font-size: 0.59rem;
        }

        .hero-meta > span:nth-child(1),
        .hero-meta > span:nth-child(4) {
            max-width: none;
        }

        .hero-scroll {
            display: grid;
            bottom: calc(var(--safe-area-bottom) + 0.45rem);
            gap: 0.2rem;
        }

        .hero-scroll-label {
            font-size: 0.68rem;
        }

        .hero-scroll svg {
            width: 2.1rem;
            height: 2.1rem;
        }
    }

    @media (min-width: 1440px) {
        .hero-content {
            grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
        }

        .hero-content :global(.ascii-field) {
            width: min(100%, 48rem);
        }

        .hero-name {
            font-size: clamp(2.95rem, 6vw, 5.75rem);
        }
    }
</style>
