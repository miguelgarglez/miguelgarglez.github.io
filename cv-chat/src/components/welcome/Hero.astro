---
import { Icon } from "astro-icon/components";
---

<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-orb hero-orb-primary"></div>
    <div class="hero-orb hero-orb-secondary"></div>
    <div class="page-shell hero-shell">
        <div class="hero-content">
            <div class="hero-copy">
                <div class="hero-intro hero-reveal">
                    <h1 class="name">Miguel García</h1>
                    <p class="title">Software Engineer</p>
                    <p class="summary">
                        Building software, scalable design systems, and
                        practical AI workflows.
                    </p>
                </div>

                <div class="contact-info">
                    <span class="contact-chip-reveal">
                        <span class="contact-chip">
                            <Icon
                                class="chip-icon"
                                name="lucide:map-pin"
                                aria-hidden="true"
                            />
                            Madrid, Spain
                        </span>
                    </span>
                    <span class="contact-chip-reveal">
                        <a
                            href="https://www.linkedin.com/in/miguel-garciag"
                            target="_blank"
                            rel="noreferrer"
                            class="contact-chip"
                        >
                            <Icon
                                class="chip-icon"
                                name="lucide:linkedin"
                                aria-hidden="true"
                            />
                            LinkedIn
                        </a>
                    </span>
                    <span class="contact-chip-reveal">
                        <a
                            href="https://x.com/miguel_garglez"
                            target="_blank"
                            rel="noreferrer"
                            class="contact-chip"
                        >
                            <Icon
                                class="chip-icon chip-icon-solid"
                                name="simple-icons:x"
                                aria-hidden="true"
                            />
                            X (Twitter)
                        </a>
                    </span>
                </div>

                <div class="cta-buttons">
                    <span class="cta-button-reveal">
                        <a href="#about" class="btn btn-primary">About Me</a>
                    </span>
                    <span class="cta-button-reveal">
                        <a href="#contact" class="btn btn-secondary"
                            >Get in Touch</a
                        >
                    </span>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { getMotionTools, prefersReducedMotion } from "../../lib/motion";

    document.addEventListener("DOMContentLoaded", async () => {
        if (prefersReducedMotion()) {
            return;
        }

        const { gsap } = await getMotionTools();

        /* ─────────────────────────────────────────────────────────
         * HERO STORYBOARD
         *
         *   0ms   intro block rises in
         * 220ms   contact chips reveal
         * 520ms   CTAs finish the sequence
         * ───────────────────────────────────────────────────────── */

        gsap.set(".hero-intro", {
            y: 36,
            opacity: 0,
        });
        gsap.set(".contact-chip-reveal, .cta-button-reveal", {
            y: 20,
            opacity: 0,
        });
        const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

        tl.to(".hero-intro", {
            y: 0,
            opacity: 1,
            duration: 0.8,
        })
            .to(
                ".contact-chip-reveal",
                {
                    y: 0,
                    opacity: 1,
                    stagger: 0.07,
                    duration: 0.5,
                },
                "-=0.34",
            )
            .to(
                ".cta-button-reveal",
                {
                    y: 0,
                    opacity: 1,
                    stagger: 0.08,
                    duration: 0.52,
                },
                "-=0.24",
            );
    });
</script>

<style>
    .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        position: relative;
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(
                circle at 12% 12%,
                color-mix(in srgb, var(--primary) 20%, transparent),
                transparent 42%
            ),
            radial-gradient(
                circle at 88% 18%,
                color-mix(in srgb, var(--secondary) 14%, transparent),
                transparent 34%
            ),
            linear-gradient(
                135deg,
                var(--bg-dark),
                var(--bg) 48%,
                var(--bg-light)
            );
        z-index: 0;
    }

    .hero-orb {
        position: absolute;
        border-radius: 999px;
        filter: blur(120px);
        opacity: 0.6;
        z-index: 0;
    }

    .hero-orb-primary {
        width: 520px;
        height: 520px;
        background: color-mix(in srgb, var(--primary) 28%, transparent);
        top: -180px;
        right: -180px;
    }

    .hero-orb-secondary {
        width: 320px;
        height: 320px;
        background: color-mix(in srgb, var(--secondary) 20%, transparent);
        bottom: -140px;
        left: -120px;
    }

    .hero-shell {
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .hero-content {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 6rem 0 4.5rem;
    }

    .hero-copy {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        max-width: 860px;
        text-align: center;
    }

    .hero-intro {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .name {
        font-size: clamp(3.2rem, 6vw, 5.8rem);
        font-weight: 700;
        color: var(--text);
        margin: 0;
        letter-spacing: -0.04em;
        line-height: 0.94;
        font-family: var(--font-display);
    }

    .title {
        font-size: clamp(1.3rem, 2.5vw, 1.95rem);
        color: var(--primary);
        margin: 0;
        font-weight: 600;
        max-width: none;
        line-height: 1.2;
        font-family: var(--font-display);
    }

    .summary {
        font-size: 1.06rem;
        line-height: 1.75;
        color: var(--text-muted);
        margin: 0;
        max-width: 44ch;
    }

    .contact-info {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
        justify-content: center;
    }

    .hero-reveal,
    .contact-chip-reveal,
    .cta-button-reveal {
        display: inline-flex;
        will-change: transform, opacity;
    }

    .contact-chip {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 1rem;
        transition:
            color 220ms ease,
            background-color 220ms ease,
            border-color 220ms ease,
            box-shadow 240ms var(--ease-out-quart),
            transform 240ms var(--ease-out-quart);
        padding: 0.72rem 1.1rem;
        border-radius: 999px;
        border: 1px solid color-mix(in srgb, var(--border) 90%, transparent);
        background: color-mix(in srgb, var(--bg-light) 74%, transparent);
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        text-align: center;
        white-space: nowrap;
        backdrop-filter: blur(10px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.14);
    }

    .contact-chip:hover {
        color: var(--text);
        border-color: color-mix(in srgb, var(--primary) 52%, var(--border));
        box-shadow: 0 18px 30px rgba(0, 0, 0, 0.2);
        transform: translateY(-2px);
    }

    .contact-chip:focus-visible,
    .btn:focus-visible {
        outline: none;
        box-shadow:
            var(--shadow-card),
            0 0 0 3px color-mix(in srgb, var(--primary) 24%, transparent);
    }

    .chip-icon {
        width: 1.05rem;
        height: 1.05rem;
        color: var(--primary);
        stroke: currentColor;
        stroke-width: 1.8;
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .chip-icon-solid {
        fill: currentColor;
        stroke: none;
    }

    .cta-buttons {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .btn {
        padding: 0.95rem 1.45rem;
        min-width: 180px;
        justify-content: center;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 600;
        transition:
            color 220ms ease,
            background-color 220ms ease,
            border-color 220ms ease,
            box-shadow 240ms var(--ease-out-quart),
            transform 240ms var(--ease-out-quart);
        border: 1px solid transparent;
        cursor: pointer;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
    }

    .btn-primary {
        background: var(--primary);
        color: #1d1204;
        box-shadow: 0 16px 28px rgba(0, 0, 0, 0.24);
    }

    .btn-primary:hover {
        background: color-mix(in srgb, var(--primary) 86%, white 14%);
        transform: translateY(-2px);
        box-shadow: 0 18px 34px rgba(0, 0, 0, 0.28);
    }

    .btn-secondary {
        background: color-mix(in srgb, var(--bg-light) 76%, transparent);
        color: var(--text);
        border-color: color-mix(in srgb, var(--border) 90%, transparent);
    }

    .btn-secondary:hover {
        background: color-mix(in srgb, var(--bg-light) 92%, transparent);
        transform: translateY(-2px);
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.16);
    }

    @media (max-width: 1023px) {
        .hero-content {
            padding: 6rem 0 3.5rem;
        }
    }

    @media (max-width: 768px) {
        .hero {
            min-height: auto;
        }

        .hero-content {
            padding: 5.5rem 1.2rem 2.5rem;
        }
    }

    @media (max-width: 620px) {
        .hero-content {
            padding-inline: 1rem;
        }

        .hero-copy {
            gap: 1.35rem;
        }

        .name {
            font-size: clamp(2.85rem, 14vw, 4.2rem);
        }

        .summary {
            max-width: 26ch;
        }

        .contact-info {
            display: grid;
            grid-template-columns: repeat(2, max-content);
            justify-content: center;
            align-items: center;
        }

        .contact-chip-reveal:first-child {
            grid-column: 1 / -1;
            justify-self: center;
        }

        .cta-buttons {
            flex-direction: column;
            width: 100%;
            align-items: center;
        }

        .btn {
            width: 100%;
            max-width: 240px;
        }
    }
</style>
