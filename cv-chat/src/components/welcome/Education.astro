---
import { Icon } from 'astro-icon/components';

const academicItems = [
  {
    period: '2022-2024',
    title: "Master's Degree in Computer Science",
    institution: 'Universidad Autónoma de Madrid',
  },
  {
    period: '2023',
    title: 'Exchange Program',
    institution: 'Aalto University · Helsinki, Finland',
  },
  {
    period: '2018-2022',
    title: "Bachelor's Degree in Computer Science",
    institution: 'Universidad Autónoma de Madrid',
  },
];

const learningItems = [
  {
    title: 'Professional Scrum Master I',
    issuer: 'Scrum.org',
    href: 'https://www.credly.com/badges/78c42e63-cb83-4914-8607-4073c40599a3/linked_in_profile',
  },
  {
    title: 'Animations on the Web',
    issuer: 'Emil Kowalski',
    href: 'https://animations.dev/certificate/6372ea11-f38d-45be-9c2f-9817e68b90a6',
  },
  {
    title: 'Google GenAI Intensive',
    issuer: 'Kaggle',
    href: 'https://www.kaggle.com/certification/badges/miguelgarglez/96',
  },
  {
    title: 'Responsible AI and Prompt Engineering',
    issuer: 'Founderz',
    href: 'https://learn.founderz.com/certificate/curso-generacion-ia-comunidad-madrid/7ca969ab-1671-4608-9c40-8b87d3bbfddf',
  },
  {
    title: 'Full Stack Open',
    issuer: 'University of Helsinki',
    href: 'https://studies.cs.helsinki.fi/stats/api/certificate/fullstackopen/en/db1060c383cd09cd6ab128fb5f864156',
  },
  {
    title: 'TOEIC - C1 CEFR Level',
    issuer: 'Capman Testing Solutions',
    href: 'https://www.linkedin.com/in/miguel-garciag/details/certifications/',
  },
];
---

<section id="education" class="education" aria-labelledby="credentials-title">
  <div class="container">
    <div class="section-heading credentials-reveal">
      <p class="section-kicker">/credentials</p>
      <h2 id="credentials-title" class="editorial-title">
        Credentials & Learning
      </h2>
      <p class="section-copy">
        Formal education and recent professional learning behind the engineering
        practice shown above.
      </p>
    </div>

    <div class="credentials-layout">
      <section class="credentials-panel credentials-reveal" aria-labelledby="academic-title">
        <div class="panel-heading">
          <p class="panel-kicker">01</p>
          <h3 id="academic-title" class="panel-title">Academic foundation</h3>
        </div>

        <ol class="credential-list credential-list--academic" role="list">
          {
            academicItems.map((item) => (
              <li class="credential-row">
                <span class="credential-period">{item.period}</span>
                <span class="credential-body">
                  <span class="credential-title">{item.title}</span>
                  <span class="credential-meta">{item.institution}</span>
                </span>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="credentials-panel credentials-reveal" aria-labelledby="learning-title">
        <div class="panel-heading">
          <p class="panel-kicker">02</p>
          <h3 id="learning-title" class="panel-title">Professional learning</h3>
        </div>

        <ol class="credential-list" role="list">
          {
            learningItems.map((item) => (
              <li>
                <a
                  class="credential-row credential-row--link"
                  href={item.href}
                  target="_blank"
                  rel="noreferrer"
                  aria-label={`View credential for ${item.title}`}
                >
                  <span class="credential-body">
                    <span class="credential-title">{item.title}</span>
                    <span class="credential-meta">{item.issuer}</span>
                  </span>
                  <Icon
                    class="credential-link-icon"
                    name="lucide:arrow-up-right"
                    aria-hidden="true"
                  />
                </a>
              </li>
            ))
          }
        </ol>
      </section>
    </div>

    <div class="credentials-prompts credentials-reveal" aria-label="Suggested chat prompts">
      <button
        type="button"
        class="agent-link"
        data-chat-prompt="What is Miguel's academic background?"
      >
        <span>Ask about academic background</span>
        <Icon name="lucide:arrow-up-right" aria-hidden="true" />
      </button>
      <button
        type="button"
        class="agent-link"
        data-chat-prompt="What has Miguel been learning recently?"
      >
        <span>Ask about recent learning</span>
        <Icon name="lucide:arrow-up-right" aria-hidden="true" />
      </button>
    </div>
  </div>
</section>

<script>
  import { getScrollMotionTools, prefersReducedMotion } from '../../lib/motion';

  const openAgentWithPrompt = (prompt) => {
    window.dispatchEvent(new CustomEvent('cv-chat:open'));
    window.dispatchEvent(
      new CustomEvent('cv-chat:prompt', {
        detail: { prompt },
      })
    );
  };

  document.addEventListener('DOMContentLoaded', async () => {
    document
      .querySelectorAll('#education [data-chat-prompt]')
      .forEach((element) => {
        element.addEventListener('click', () => {
          openAgentWithPrompt(element.getAttribute('data-chat-prompt') ?? '');
        });
      });

    if (prefersReducedMotion()) {
      return;
    }

    const { gsap } = await getScrollMotionTools();

    gsap.set('#education .credentials-reveal', { y: 18, opacity: 0 });
    gsap.set('#education .credential-row', { y: 10, opacity: 0 });

    gsap.to('#education .credentials-reveal', {
      y: 0,
      opacity: 1,
      duration: 0.34,
      stagger: 0.08,
      ease: 'power3.out',
      force3D: true,
      scrollTrigger: {
        trigger: '#education',
        start: 'top 72%',
        end: 'bottom 72%',
        toggleActions: 'play none none reverse',
      },
    });

    gsap.to('#education .credential-row', {
      y: 0,
      opacity: 1,
      duration: 0.24,
      stagger: 0.045,
      ease: 'power3.out',
      force3D: true,
      scrollTrigger: {
        trigger: '#education .credentials-layout',
        start: 'top 78%',
        end: 'bottom 78%',
        toggleActions: 'play none none reverse',
      },
    });
  });
</script>

<style>
  .education {
    padding: 5rem 2rem;
    background: var(--bg);
    color: var(--text);
  }

  .container {
    max-width: 1180px;
    margin: 0 auto;
  }

  .section-heading {
    max-width: 720px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .section-kicker,
  .panel-kicker {
    margin: 0;
    color: var(--primary);
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .section-copy {
    max-width: 58ch;
    margin: 1.15rem auto 0;
    color: var(--text-muted);
    font-size: clamp(1rem, 1.7vw, 1.1rem);
    line-height: 1.7;
  }

  .credentials-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.2rem;
    align-items: start;
  }

  .credentials-panel {
    min-width: 0;
    padding: clamp(1.2rem, 2.2vw, 1.8rem);
    border: 1px solid var(--border-muted);
    border-radius: 10px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.035), transparent 34%),
      var(--bg-light);
  }

  .panel-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--border-muted);
  }

  .panel-title {
    margin: 0;
    color: var(--text);
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    font-weight: 400;
    line-height: 1.2;
  }

  .credential-list {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .credential-row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    min-height: 4.25rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border-muted);
  }

  .credential-list > li:last-child .credential-row,
  .credential-list--academic > .credential-row:last-child {
    border-bottom: 0;
  }

  .credential-row--link {
    color: inherit;
    text-decoration: none;
    transition:
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms var(--ease-out-quart);
  }

  .credential-row--link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 6px;
    border-radius: 8px;
  }

  .credential-period {
    min-width: 5.4rem;
    color: var(--primary);
    font-family: var(--font-mono, monospace);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .credential-body {
    display: grid;
    gap: 0.28rem;
    min-width: 0;
  }

  .credential-title {
    color: var(--text);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .credential-meta {
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .credential-link-icon {
    width: 18px;
    height: 18px;
    color: var(--primary);
    opacity: 0.72;
    stroke: currentColor;
    stroke-width: 2;
    transition:
      opacity 180ms ease,
      transform 180ms var(--ease-out-quart);
  }

  .credentials-prompts {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1.85rem;
  }

  .agent-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.35rem;
    padding: 0.1rem 0;
    border: 0;
    border-bottom: 1px solid
      color-mix(in srgb, var(--primary) 45%, transparent);
    background: transparent;
    color: var(--text);
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      color 180ms ease,
      border-color 180ms ease,
      transform 180ms var(--ease-out-quart);
  }

  .agent-link svg {
    width: 0.85rem;
    height: 0.85rem;
    color: var(--primary);
    transition: transform 180ms var(--ease-out-quart);
  }

  .agent-link:active {
    transform: scale(0.97);
  }

  .agent-link:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px
      color-mix(in srgb, var(--primary) 24%, transparent);
  }

  @media (hover: hover) and (pointer: fine) {
    .credential-row--link:hover {
      border-color: rgba(242, 169, 59, 0.48);
      transform: translateX(2px);
    }

    .credential-row--link:hover .credential-link-icon {
      opacity: 1;
      transform: translate(2px, -2px);
    }

    .agent-link:hover {
      color: var(--primary);
      border-color: var(--primary);
      transform: translateY(-1px);
    }

    .agent-link:hover svg {
      transform: translate(2px, -2px);
    }
  }

  @media (max-width: 860px) {
    .education {
      padding: 3.5rem 1rem;
    }

    .section-heading {
      text-align: left;
      margin-bottom: 2rem;
    }

    .section-copy {
      margin-left: 0;
      margin-right: 0;
    }

    .credentials-layout {
      grid-template-columns: 1fr;
    }

    .credentials-prompts {
      justify-content: flex-start;
    }
  }

  @media (max-width: 560px) {
    .credentials-panel {
      padding: 1rem;
      border-radius: 8px;
    }

    .panel-heading {
      display: grid;
      gap: 0.35rem;
    }

    .credential-row {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.75rem;
      min-height: auto;
      padding: 0.95rem 0;
    }

    .credential-list--academic .credential-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }

    .credential-period {
      min-width: 0;
    }

    .agent-link {
      width: 100%;
      justify-content: center;
    }
  }
</style>
