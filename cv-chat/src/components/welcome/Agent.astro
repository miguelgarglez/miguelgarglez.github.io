---
import { Icon } from 'astro-icon/components';

const engineeringNotes = [
  {
    title: 'Grounded retrieval',
    body: 'The worker selects profile facts, CV sections, projects, and recent public updates before calling the model.',
  },
  {
    title: 'Context engineering',
    body: 'Questions are classified by likely audience and intent, then assembled into a compact system prompt with explicit answer rules.',
  },
  {
    title: 'Deterministic evals',
    body: 'Node tests verify that key questions retrieve the expected profile context without depending on a live LLM response.',
  },
  {
    title: 'Streaming UX',
    body: 'The Cloudflare Worker adapts upstream SSE into the AI SDK UI message stream used by the drawer chat.',
  },
  {
    title: 'Operational guardrails',
    body: 'CORS, rate limits, upstream retries, timeout handling, and a secondary backend keep failures visible and recoverable.',
  },
];

const prompts = [
  'How does this CV chat work?',
  'How does Miguel use AI in engineering?',
];
---

<section id="agent" class="agent">
  <div class="container">
    <div class="agent-layout">
      <div class="agent-copy">
        <p class="section-kicker">/agent</p>
        <h2 class="section-title editorial-title">Profile Chat</h2>
        <p class="agent-description">
          A small AI interface over Miguel&apos;s curated CV data. It is meant
          to answer focused questions about experience, projects, working style,
          education, and AI engineering practice.
        </p>
        <div class="agent-actions">
          <button type="button" class="agent-open" data-agent-open>
            <Icon name="lucide:message-circle" aria-hidden="true" />
            Try the chat
          </button>
          {
            prompts.map((prompt) => (
              <button type="button" class="agent-prompt" data-chat-prompt={prompt}>
                {prompt}
              </button>
            ))
          }
        </div>
      </div>

      <div class="agent-notes" aria-label="AI engineering highlights">
        {
          engineeringNotes.map((note) => (
            <article class="agent-note">
              <h3>{note.title}</h3>
              <p>{note.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import { getScrollMotionTools, prefersReducedMotion } from '../../lib/motion';

  const openAgent = () => {
    window.dispatchEvent(new CustomEvent('cv-chat:open'));
  };

  const openAgentWithPrompt = (prompt) => {
    window.dispatchEvent(
      new CustomEvent('cv-chat:prompt', {
        detail: { prompt },
      }),
    );
  };

  document.addEventListener('DOMContentLoaded', async () => {
    document.querySelectorAll('[data-agent-open]').forEach((element) => {
      element.addEventListener('click', openAgent);
    });

    document.querySelectorAll('#agent [data-chat-prompt]').forEach((element) => {
      element.addEventListener('click', () => {
        openAgentWithPrompt(element.getAttribute('data-chat-prompt') ?? '');
      });
    });

    if (prefersReducedMotion()) {
      return;
    }

    const { gsap } = await getScrollMotionTools();

    gsap.set('#agent .agent-copy, #agent .agent-note', { y: 28, opacity: 0 });

    gsap.to('#agent .agent-copy, #agent .agent-note', {
      y: 0,
      opacity: 1,
      duration: 0.65,
      ease: 'power3.out',
      stagger: 0.06,
      scrollTrigger: {
        trigger: '#agent',
        start: 'top 75%',
        end: 'bottom 75%',
        toggleActions: 'play none none reverse',
      },
    });
  });
</script>

<style>
  .agent {
    padding: clamp(4rem, 8vw, 6rem) 1.25rem;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg-light) 42%, transparent),
        var(--bg) 76%
      );
    color: var(--text);
    overflow: hidden;
    position: relative;
  }

  .agent::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--border) 28%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--border) 18%, transparent) 1px,
        transparent 1px
      );
    background-size: 96px 96px;
    mask-image: linear-gradient(180deg, transparent, black 20%, black 82%, transparent);
    opacity: 0.12;
    pointer-events: none;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  .agent-layout {
    display: grid;
    grid-template-columns: minmax(18rem, 0.82fr) minmax(0, 1.18fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .agent-copy {
    display: grid;
    gap: 1.2rem;
  }

  .section-title {
    margin: 0;
    text-align: left;
    font-size: clamp(2.2rem, 4vw, 3.85rem);
  }

  .agent-description {
    margin: 0;
    max-width: 38rem;
    color: var(--text-muted);
    font-size: clamp(1rem, 1.35vw, 1.12rem);
    line-height: 1.7;
  }

  .agent-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 0.4rem;
  }

  .agent-open,
  .agent-prompt {
    border: 1px solid color-mix(in srgb, var(--primary) 42%, var(--border));
    border-radius: 999px;
    cursor: pointer;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms var(--ease-out-quart);
  }

  .agent-open {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    background: var(--primary);
    color: var(--primary-foreground);
    padding: 0.68rem 1rem;
    font-weight: 650;
  }

  .agent-open svg {
    width: 1rem;
    height: 1rem;
  }

  .agent-prompt {
    background: color-mix(in srgb, var(--bg-light) 64%, transparent);
    color: var(--text-muted);
    padding: 0.64rem 0.9rem;
    font-size: 0.82rem;
  }

  .agent-open:active,
  .agent-prompt:active {
    transform: scale(0.97);
  }

  .agent-open:focus-visible,
  .agent-prompt:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px var(--focus-ring-soft);
  }

  .agent-notes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--border);
  }

  .agent-note {
    min-height: 8.2rem;
    padding: 1.05rem 1rem 1.2rem 0;
    border-bottom: 1px solid var(--border-muted);
  }

  .agent-note:nth-child(odd) {
    padding-right: 1.25rem;
    border-right: 1px solid var(--border-muted);
  }

  .agent-note:nth-child(even) {
    padding-left: 1.25rem;
  }

  .agent-note h3 {
    margin: 0;
    color: var(--text);
    font-family: var(--font-mono, monospace);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .agent-note p {
    margin: 0.55rem 0 0;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.58;
  }

  @media (hover: hover) and (pointer: fine) {
    .agent-open:hover {
      border-color: var(--primary);
      box-shadow: var(--shadow-glow);
      transform: translateY(-1px);
    }

    .agent-prompt:hover {
      border-color: color-mix(in srgb, var(--primary) 62%, var(--border));
      color: var(--text);
      transform: translateY(-1px);
    }
  }

  @media (max-width: 900px) {
    .agent-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .agent {
      padding: 3.5rem 1rem;
    }

    .section-title {
      font-size: clamp(1.9rem, 10vw, 2.7rem);
    }

    .agent-description {
      font-size: 0.95rem;
      line-height: 1.58;
    }

    .agent-actions {
      display: grid;
    }

    .agent-open,
    .agent-prompt {
      width: 100%;
    }

    .agent-notes {
      grid-template-columns: 1fr;
    }

    .agent-note,
    .agent-note:nth-child(odd),
    .agent-note:nth-child(even) {
      min-height: 0;
      padding: 1rem 0;
      border-right: 0;
    }
  }
</style>
