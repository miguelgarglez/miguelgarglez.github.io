<section id="agent" class="agent">
  <div class="container">
    <div class="agent-shell">
      <div class="agent-copy">
        <p class="agent-kicker">/ agent</p>
        <h2 class="section-title">How the drawer works</h2>
        <p class="agent-description">
          Open the agent to ask about experience, projects, workflow, or how this
          CV is structured. It is meant to stay accessible without taking over the
          page.
        </p>
      </div>

      <div class="agent-panel">
        <div class="agent-panel-head">
          <span class="agent-status">status: ready</span>
          <button type="button" class="agent-open" data-agent-open>
            Open agent
          </button>
        </div>

        <div class="agent-panel-body">
          <div class="agent-line">
            <span>context</span>
            <strong>profile / experience / signals</strong>
          </div>
          <div class="agent-line">
            <span>mode</span>
            <strong>dossier</strong>
          </div>
        </div>

        <div class="agent-prompts" aria-label="Suggested prompts">
          <button type="button" class="agent-chip" data-chat-prompt="What kind of engineer is Miguel?">
            What kind of engineer is Miguel?
          </button>
          <button type="button" class="agent-chip" data-chat-prompt="How does Miguel use AI in engineering?">
            How does Miguel use AI in engineering?
          </button>
          <button type="button" class="agent-chip" data-chat-prompt="How does this CV chat work?">
            How does this CV chat work?
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { getScrollMotionTools, prefersReducedMotion } from '../../lib/motion';

  const openAgent = () => {
    window.dispatchEvent(new CustomEvent('cv-chat:open'));
  };

  const openAgentWithPrompt = (prompt) => {
    window.dispatchEvent(
      new CustomEvent('cv-chat:prompt', {
        detail: { prompt },
      }),
    );
  };

  document.addEventListener('DOMContentLoaded', async () => {
    document.querySelectorAll('[data-agent-open]').forEach((element) => {
      element.addEventListener('click', openAgent);
    });

    document.querySelectorAll('#agent [data-chat-prompt]').forEach((element) => {
      element.addEventListener('click', () => {
        openAgentWithPrompt(element.getAttribute('data-chat-prompt') ?? '');
      });
    });

    if (prefersReducedMotion()) {
      return;
    }

    const { gsap } = await getScrollMotionTools();

    gsap.set('#agent .agent-copy, #agent .agent-panel', { y: 42, opacity: 0 });
    gsap.set('#agent .agent-chip', { y: 14, opacity: 0 });

    gsap.to('#agent .agent-copy, #agent .agent-panel', {
      y: 0,
      opacity: 1,
      duration: 0.75,
      ease: 'power3.out',
      stagger: 0.08,
      scrollTrigger: {
        trigger: '#agent',
        start: 'top 75%',
        end: 'bottom 75%',
        toggleActions: 'play none none reverse',
      },
    });

    gsap.to('#agent .agent-chip', {
      y: 0,
      opacity: 1,
      duration: 0.5,
      stagger: 0.08,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#agent .agent-prompts',
        start: 'top 80%',
        end: 'bottom 80%',
        toggleActions: 'play none none reverse',
      },
    });
  });
</script>

