---
import { Icon } from 'astro-icon/components';
---

<section id="agent" class="agent">
  <div class="container">
    <div class="agent-shell">
      <div class="agent-copy">
        <p class="section-kicker">/agent</p>
        <h2 class="section-title editorial-title">Ask the Dossier</h2>
        <p class="agent-description">
          A lightweight CV agent that can answer from the same professional
          story shown on the page: experience, signals, skills, education, and
          working style.
        </p>
      </div>

      <div class="agent-panel">
        <div class="agent-panel-head">
          <div>
            <span class="agent-status">status: ready</span>
            <p class="agent-panel-title">Profile context loaded</p>
          </div>
          <button type="button" class="agent-open" data-agent-open>
            <Icon name="lucide:message-circle" aria-hidden="true" />
            Open agent
          </button>
        </div>

        <div class="agent-panel-body">
          <div class="agent-line">
            <span>context</span>
            <strong>profile / experience / signals</strong>
          </div>
          <div class="agent-line">
            <span>mode</span>
            <strong>dossier</strong>
          </div>
        </div>

        <div class="agent-prompts" aria-label="Suggested prompts">
          <button type="button" class="agent-link" data-chat-prompt="What kind of engineer is Miguel?">
            <span>What kind of engineer is Miguel?</span>
            <Icon name="lucide:arrow-up-right" aria-hidden="true" />
          </button>
          <button type="button" class="agent-link" data-chat-prompt="How does Miguel use AI in engineering?">
            <span>How does Miguel use AI in engineering?</span>
            <Icon name="lucide:arrow-up-right" aria-hidden="true" />
          </button>
          <button type="button" class="agent-link" data-chat-prompt="How does this CV chat work?">
            <span>How does this CV chat work?</span>
            <Icon name="lucide:arrow-up-right" aria-hidden="true" />
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { getScrollMotionTools, prefersReducedMotion } from '../../lib/motion';

  const openAgent = () => {
    window.dispatchEvent(new CustomEvent('cv-chat:open'));
  };

  const openAgentWithPrompt = (prompt) => {
    window.dispatchEvent(
      new CustomEvent('cv-chat:prompt', {
        detail: { prompt },
      }),
    );
  };

  document.addEventListener('DOMContentLoaded', async () => {
    document.querySelectorAll('[data-agent-open]').forEach((element) => {
      element.addEventListener('click', openAgent);
    });

    document.querySelectorAll('#agent [data-chat-prompt]').forEach((element) => {
      element.addEventListener('click', () => {
        openAgentWithPrompt(element.getAttribute('data-chat-prompt') ?? '');
      });
    });

    if (prefersReducedMotion()) {
      return;
    }

    const { gsap } = await getScrollMotionTools();

    gsap.set('#agent .agent-copy, #agent .agent-panel', { y: 42, opacity: 0 });
    gsap.set('#agent .agent-link', { y: 14, opacity: 0 });

    gsap.to('#agent .agent-copy, #agent .agent-panel', {
      y: 0,
      opacity: 1,
      duration: 0.75,
      ease: 'power3.out',
      stagger: 0.08,
      scrollTrigger: {
        trigger: '#agent',
        start: 'top 75%',
        end: 'bottom 75%',
        toggleActions: 'play none none reverse',
      },
    });

    gsap.to('#agent .agent-link', {
      y: 0,
      opacity: 1,
      duration: 0.5,
      stagger: 0.08,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#agent .agent-prompts',
        start: 'top 80%',
        end: 'bottom 80%',
        toggleActions: 'play none none reverse',
      },
    });
  });
</script>

<style>
  .agent {
    padding: clamp(4rem, 8vw, 6rem) 1.25rem;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg-light) 52%, transparent),
        var(--bg) 78%
      );
    color: var(--text);
    overflow: hidden;
    position: relative;
  }

  .agent::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--border) 34%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--border) 22%, transparent) 1px,
        transparent 1px
      );
    background-size: 96px 96px;
    mask-image: linear-gradient(180deg, transparent, black 18%, black 84%, transparent);
    opacity: 0.14;
    pointer-events: none;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  .agent-shell {
    display: grid;
    grid-template-columns: minmax(16rem, 0.82fr) minmax(0, 1.18fr);
    gap: 0;
    align-items: stretch;
  }

  .agent-copy,
  .agent-panel {
    border: 1px solid var(--border);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg-light) 84%, transparent),
        color-mix(in srgb, var(--bg) 96%, transparent)
      );
    min-width: 0;
  }

  .agent-copy {
    padding: clamp(1.5rem, 3vw, 2rem);
    display: grid;
    align-content: start;
    min-height: 17rem;
  }

  .section-title {
    margin: 0;
    text-align: left;
    font-size: clamp(2.2rem, 4vw, 3.85rem);
  }

  .agent-description {
    margin: 1.2rem 0 0;
    max-width: 38rem;
    color: var(--text-muted);
    line-height: 1.7;
    font-size: clamp(1rem, 1.35vw, 1.12rem);
  }

  .agent-panel {
    padding: clamp(1.25rem, 2.5vw, 1.65rem);
    border-left-width: 0;
    display: grid;
    gap: 1.25rem;
  }

  .agent-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .agent-status {
    color: var(--text-muted);
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .agent-panel-title {
    margin: 0.5rem 0 0;
    color: var(--text);
    font-family: var(--font-mono, monospace);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .agent-open {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    border: 1px solid color-mix(in srgb, var(--primary) 42%, var(--border));
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    color: var(--text);
    border-radius: 999px;
    padding: 0.68rem 0.95rem;
    cursor: pointer;
    font-weight: 600;
    transition:
      background-color 160ms ease,
      transform 160ms var(--ease-out-quart),
      border-color 160ms var(--ease-out-quart);
  }

  .agent-open svg {
    width: 1rem;
    height: 1rem;
    color: var(--primary);
  }

  .agent-open:active {
    transform: scale(0.97);
  }

  .agent-open:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px var(--focus-ring-soft);
  }

  .agent-panel-body {
    display: grid;
    gap: 0;
    padding: 0;
  }

  .agent-line {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem 1rem;
    border: 1px solid var(--border-muted);
    border-top-width: 0;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    font-family: var(--font-mono, monospace);
    font-size: 0.85rem;
  }

  .agent-line:first-child {
    border-top-width: 1px;
  }

  .agent-line span {
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .agent-line strong {
    color: var(--text);
    font-weight: 500;
    text-align: right;
  }

  .agent-prompts {
    display: flex;
    flex-wrap: wrap;
    gap: 1.1rem 1.35rem;
  }

  .agent-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.35rem;
    padding: 0.1rem 0;
    border: 0;
    border-bottom: 1px solid
      color-mix(in srgb, var(--primary) 45%, transparent);
    background: transparent;
    color: var(--text);
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    text-align: left;
    line-height: 1.3;
    transition:
      color 180ms ease,
      border-color 180ms ease,
      transform 180ms var(--ease-out-quart);
  }

  .agent-link svg {
    width: 0.85rem;
    height: 0.85rem;
    color: var(--primary);
    transition: transform 180ms var(--ease-out-quart);
  }

  .agent-link:active {
    transform: scale(0.97);
  }

  .agent-link:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px var(--focus-ring-soft);
  }

  @media (hover: hover) and (pointer: fine) {
    .agent-open:hover {
      background: color-mix(in srgb, var(--bg-light) 92%, var(--primary) 8%);
      transform: translateY(-1px);
      border-color: color-mix(in srgb, var(--primary) 60%, var(--border));
    }

    .agent-link:hover {
      color: var(--primary);
      border-color: var(--primary);
      transform: translateY(-1px);
    }

    .agent-link:hover svg {
      transform: translate(2px, -2px);
    }
  }

  @media (max-width: 900px) {
    .agent-shell {
      grid-template-columns: 1fr;
    }

    .agent-panel {
      border-left-width: 1px;
      border-top-width: 0;
    }
  }

  @media (max-width: 640px) {
    .agent {
      padding: 3.5rem 1rem;
    }

    .agent-copy,
    .agent-panel {
      padding: 1.15rem 0;
      border-right-width: 0;
      border-left-width: 0;
      background: transparent;
    }

    .section-title {
      font-size: clamp(1.9rem, 10vw, 2.7rem);
    }

    .agent-description {
      font-size: 0.95rem;
      line-height: 1.58;
    }

    .agent-panel-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .agent-line {
      align-items: flex-start;
      flex-direction: column;
      padding: 0.8rem 0;
      border-right-width: 0;
      border-left-width: 0;
      background: transparent;
    }

    .agent-line strong {
      text-align: left;
    }

    .agent-open {
      width: 100%;
    }
  }
</style>
