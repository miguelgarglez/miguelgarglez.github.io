---

---

<div
    class="ascii-field"
    aria-hidden="true"
    data-ascii-field
>
    <div class="ascii-field-surface">
        <div class="ascii-field-glow"></div>
        <pre
            class="ascii-field-art"
            data-ascii-art>  ..::---===+++***+++===---::..
 ..::--==+++***###***+++==--::..
..::--==++***#####***++==--::..
.::--==++***#######***++==--::.
::--==++***#######***++==--::..
::--==++***#####***++==--::..
.::--==++***#######***++==--::.
..::--==++***#####***++==--::..
 ..::--==+++***###***+++==--::..
  ..::---===+++***+++===---::..</pre>
    </div>
</div>

<script>
    import { prefersReducedMotion } from "../../lib/motion";

    const glyphs = [" ", ".", ":", "-", "=", "+", "*", "#"];
    const compactGlyphs = [" ", ".", ":", "-", "=", "+"];

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const lerp = (a, b, t) => a + (b - a) * t;

    const smoothstep = (t) => {
        const x = clamp(t, 0, 1);
        return x * x * (3 - 2 * x);
    };

    const hash2 = (x, y) => {
        const s = Math.sin(x * 127.1 + y * 311.7) * 43758.5453;
        return s - Math.floor(s);
    };

    const noise2d = (x, y) => {
        const ix = Math.floor(x);
        const iy = Math.floor(y);
        const fx = smoothstep(x - ix);
        const fy = smoothstep(y - iy);
        const a = hash2(ix, iy);
        const b = hash2(ix + 1, iy);
        const c = hash2(ix, iy + 1);
        const d = hash2(ix + 1, iy + 1);
        return lerp(lerp(a, b, fx), lerp(c, d, fx), fy);
    };

    const fbm = (x, y, octaves = 2) => {
        let value = 0;
        let amplitude = 0.5;
        let frequency = 1;

        for (let i = 0; i < octaves; i += 1) {
            value += amplitude * noise2d(x * frequency, y * frequency);
            amplitude *= 0.5;
            frequency *= 2.1;
        }

        return value;
    };

    const sampleAtmosphere = (nx, ny, pointerX, pointerY) => {
        const px = (pointerX - 0.5) * 0.62;
        const py = (pointerY - 0.48) * 0.52;

        const warpA = fbm(nx * 2.5 + px * 1.35 + 1.4, ny * 2.3 + py * 1.2, 3);
        const warpB = fbm(
            nx * 2.5 + 4.8 - px * 0.95,
            ny * 2.3 + 2.4 + py * 0.85,
            3,
        );
        const wx = nx + px * 0.88 + (warpA - 0.5) * 0.32;
        const wy = ny + py * 0.76 + (warpB - 0.5) * 0.26;

        const cloudA = fbm(wx * 3.0 + px * 0.4, wy * 1.9 + py * 0.35, 4);
        const cloudB = fbm(wx * 1.6 + 3.1, wy * 4.0, 3);
        const cloudC = fbm(wx * 5.2 + 0.8, wy * 3.2, 2);

        const bands =
            Math.sin((wy + cloudA * 0.2) * Math.PI * 3.8) * 0.5 + 0.5;
        const turbulence = (cloudB - 0.5) * 0.42 + (cloudC - 0.5) * 0.2;
        const vortex =
            Math.sin((wx * 2.6 + wy * 1.3 + px * 3.4) * Math.PI) * 0.09;

        const limb = Math.hypot((nx - 0.5) * 0.96, (ny - 0.48) * 0.9);
        const atmosphere = clamp(1 - Math.pow(limb / 0.54, 2.4), 0, 1);

        const cursorDist = Math.hypot(
            (nx - pointerX) * 1.14,
            (ny - pointerY) * 0.98,
        );
        const cursorPull = Math.pow(clamp(1 - cursorDist * 3.4, 0, 1), 1.6) * 0.26;

        const energy =
            0.14 +
            bands * 0.44 +
            cloudA * 0.2 +
            turbulence +
            vortex +
            atmosphere * 0.16 +
            cursorPull;

        return clamp(energy * (0.7 + atmosphere * 0.3), 0, 1);
    };

    const buildBootFrame = (cols, rows, now) => {
        const label = "loading";
        const cycle = (now % 1420) / 1420;
        const typedLength =
            cycle < 0.42
                ? Math.ceil((cycle / 0.42) * label.length)
                : cycle < 0.64
                  ? label.length
                  : cycle < 0.9
                    ? Math.max(
                          0,
                          label.length -
                              Math.ceil(((cycle - 0.64) / 0.26) * label.length),
                      )
                    : 0;
        const cursor = Math.floor(now / 180) % 2 === 0 ? "_" : " ";
        const text =
            typedLength > 0 ? `${label.slice(0, typedLength)}${cursor}` : cursor;
        const rowIndex = Math.floor(rows * 0.48);
        const colIndex = Math.max(0, Math.floor((cols - text.length) / 2));

        let output = "";

        for (let row = 0; row < rows; row += 1) {
            if (row === rowIndex) {
                output +=
                    " ".repeat(colIndex) +
                    text +
                    " ".repeat(Math.max(0, cols - colIndex - text.length));
            } else {
                output += " ".repeat(cols);
            }

            output += row < rows - 1 ? "\n" : "";
        }

        return output;
    };

    const buildField = (
        x,
        y,
        compact = false,
        largeDesktop = false,
        smallMobile = false,
        ripples = [],
        now = 0,
        introRevealProgress = 1,
    ) => {
        const cols = smallMobile ? 64 : compact ? 72 : largeDesktop ? 120 : 96;
        const rows = smallMobile ? 56 : compact ? 72 : largeDesktop ? 104 : 84;
        const chars = compact ? compactGlyphs : glyphs;

        if (introRevealProgress < 0) {
            return buildBootFrame(cols, rows, now);
        }

        let output = "";

        for (let row = 0; row < rows; row += 1) {
            const ny = rows === 1 ? 0.5 : row / (rows - 1);
            let line = "";

            for (let col = 0; col < cols; col += 1) {
                const nx = cols === 1 ? 0.5 : col / (cols - 1);
                const revealDistance = Math.hypot(
                    (nx - 0.5) * 1.04,
                    (ny - 0.48) * 0.9,
                );
                let energy = sampleAtmosphere(nx, ny, x, y);
                let rippleEnergy = 0;

                for (const ripple of ripples) {
                    for (let echo = 0; echo < 3; echo += 1) {
                        const age = now - ripple.startedAt - echo * 135;
                        if (age < 0 || age > 1050) continue;

                        const progress = age / 1050;
                        const rippleDistance = Math.hypot(
                            (nx - ripple.x) * 1.12,
                            (ny - ripple.y) * 0.92,
                        );
                        const ring = Math.abs(
                            rippleDistance - progress * (0.48 + echo * 0.08),
                        );
                        const echoStrength = 1 - echo * 0.22;
                        const envelope =
                            (1 - progress) *
                            echoStrength *
                            clamp(1 - ring * 24, 0, 1);

                        rippleEnergy += envelope * 0.58;
                    }
                }

                energy = clamp(energy + rippleEnergy, 0, 1);
                const index = Math.min(
                    chars.length - 1,
                    Math.max(0, Math.floor(energy * (chars.length - 1))),
                );

                if (introRevealProgress < 1) {
                    const easedReveal =
                        1 - Math.pow(1 - introRevealProgress, 2.2);
                    const noiseEdge =
                        (fbm(nx * 8.2 + now * 0.00035, ny * 7.4, 2) - 0.5) *
                        0.09;
                    const threshold = easedReveal * 0.92 - 0.06 + noiseEdge;
                    const edge = Math.abs(revealDistance - threshold);
                    const feather = clamp(1 - edge / 0.085, 0, 1);
                    const hasArrived = revealDistance < threshold;

                    if (!hasArrived && feather <= 0) {
                        line += " ";
                        continue;
                    }

                    if (!hasArrived && feather > 0) {
                        const edgeIndex = Math.min(
                            chars.length - 1,
                            Math.max(
                                index,
                                Math.floor(
                                    (chars.length - 2) * Math.pow(feather, 0.62),
                                ),
                            ),
                        );
                        line += chars[edgeIndex];
                        continue;
                    }
                }

                line += chars[index];
            }

            output += line + (row < rows - 1 ? "\n" : "");
        }

        return output;
    };

    document.addEventListener("DOMContentLoaded", () => {
        const field = document.querySelector("[data-ascii-field]");
        const art = document.querySelector("[data-ascii-art]");

        if (!(field instanceof HTMLElement) || !(art instanceof HTMLElement)) {
            return;
        }

        const compactQuery = window.matchMedia("(max-width: 640px)");
        const smallMobileQuery = window.matchMedia(
            "(max-width: 350px) and (max-height: 775px)",
        );
        const largeDesktopQuery = window.matchMedia("(min-width: 1440px)");
        const shouldReduce = prefersReducedMotion();
        const canFollowPointer =
            !shouldReduce &&
            window.matchMedia("(hover: hover) and (pointer: fine)").matches;
        const canRipple = !shouldReduce;

        const centerX = 0.5;
        const centerY = 0.48;
        const interactionFrameInterval = 1000 / 30;
        const idleFrameInterval = 1000 / 20;
        let artRect = null;
        let ripples = [];
        let introRevealProgress = shouldReduce ? 1 : -1;

        const isIntroActive = () => introRevealProgress < 1;

        const syncIntroState = () => {
            field.toggleAttribute("data-intro", isIntroActive());
        };

        const render = (x, y, now = window.performance.now()) => {
            const normalizedX = clamp(x, 0, 1);
            const normalizedY = clamp(y, 0, 1);
            const isCompact = compactQuery.matches;
            const isSmallMobile = smallMobileQuery.matches;
            const isLargeDesktop = largeDesktopQuery.matches;

            art.textContent = buildField(
                normalizedX,
                normalizedY,
                isCompact,
                isLargeDesktop,
                isSmallMobile,
                ripples,
                now,
                introRevealProgress,
            );
            field.style.setProperty(
                "--field-x",
                `${(normalizedX * 100).toFixed(2)}%`,
            );
            field.style.setProperty(
                "--field-y",
                `${(normalizedY * 100).toFixed(2)}%`,
            );
            syncIntroState();
        };

        // Keep the glow locked to the rendered ASCII bounds so it reads as a
        // material highlight over the characters, not as a floating blob.
        const syncGlowBounds = () => {
            artRect = art.getBoundingClientRect();

            field.style.setProperty("--glow-width", `${artRect.width}px`);
            field.style.setProperty("--glow-height", `${artRect.height}px`);
        };

        const syncResponsiveState = () => {
            render(centerX, centerY);
            syncGlowBounds();
        };

        let responsiveFrame = 0;

        const scheduleResponsiveState = () => {
            if (responsiveFrame) return;

            responsiveFrame = window.requestAnimationFrame(() => {
                responsiveFrame = 0;
                syncResponsiveState();
            });
        };

        syncIntroState();
        syncResponsiveState();

        window.addEventListener("resize", scheduleResponsiveState, {
            passive: true,
        });
        window.addEventListener("orientationchange", scheduleResponsiveState, {
            passive: true,
        });

        if (shouldReduce) {
            return;
        }

        let renderFrame = 0;
        let idleFrame = 0;
        let introFrame = 0;
        let rippleFrame = 0;
        let resumeIdleTimer = 0;
        let glowFrame = 0;
        let nextX = centerX;
        let nextY = centerY;
        let phase = 0;
        let lastIdleRender = 0;
        let lastRippleRender = 0;
        let lastIntroRender = 0;
        let isHovering = false;
        let isVisible = true;

        const setGlow = (value) => {
            if (isIntroActive()) {
                field.style.setProperty("--glow-opacity", "0");
                return;
            }

            field.style.setProperty("--glow-opacity", `${value}`);
        };

        const startIntroReveal = () => {
            const startedAt = window.performance.now();
            const delay = 1560;
            const duration = 1680;

            const tick = (now) => {
                if (!isVisible) {
                    introFrame = 0;
                    return;
                }

                if (now - lastIntroRender < interactionFrameInterval) {
                    introFrame = window.requestAnimationFrame(tick);
                    return;
                }

                lastIntroRender = now;
                const revealElapsed = now - startedAt - delay;
                introRevealProgress =
                    revealElapsed < 0
                        ? -1
                        : clamp(revealElapsed / duration, 0, 1);
                render(centerX, centerY, now);

                if (introRevealProgress < 1) {
                    introFrame = window.requestAnimationFrame(tick);
                    return;
                }

                introFrame = 0;
                syncIntroState();
                startIdle();
            };

            if (!introFrame) {
                stopIdle();
                introFrame = window.requestAnimationFrame(tick);
            }
        };

        const tickIdle = (now) => {
            if (!isVisible) {
                idleFrame = 0;
                return;
            }

            if (now - lastIdleRender < idleFrameInterval) {
                idleFrame = window.requestAnimationFrame(tickIdle);
                return;
            }

            lastIdleRender = now;
            phase += 0.03;

            const x = centerX + Math.sin(phase * 1.1) * 0.045;
            const y = centerY + Math.cos(phase * 0.9) * 0.03;

            render(x, y, now);

            if (!isHovering) {
                idleFrame = window.requestAnimationFrame(tickIdle);
            } else {
                idleFrame = 0;
            }
        };

        const startIdle = () => {
            if (idleFrame || isHovering || !isVisible || isIntroActive()) return;
            idleFrame = window.requestAnimationFrame(tickIdle);
        };

        const stopIdle = () => {
            if (idleFrame) {
                window.cancelAnimationFrame(idleFrame);
                idleFrame = 0;
            }
        };

        const stopIntroReveal = () => {
            if (introFrame) {
                window.cancelAnimationFrame(introFrame);
                introFrame = 0;
            }
        };

        const scheduleIdleResume = () => {
            if (resumeIdleTimer) {
                window.clearTimeout(resumeIdleTimer);
            }

            resumeIdleTimer = window.setTimeout(() => {
                resumeIdleTimer = 0;
                startIdle();
            }, 1200);
        };

        const stopRipples = () => {
            if (rippleFrame) {
                window.cancelAnimationFrame(rippleFrame);
                rippleFrame = 0;
            }
        };

        const pruneRipples = (now) => {
            ripples = ripples.filter((ripple) => now - ripple.startedAt <= 1100);
        };

        const tickRipples = (now) => {
            if (!isVisible) {
                rippleFrame = 0;
                return;
            }

            if (now - lastRippleRender < interactionFrameInterval) {
                rippleFrame = window.requestAnimationFrame(tickRipples);
                return;
            }

            lastRippleRender = now;
            pruneRipples(now);
            render(centerX, centerY, now);

            if (ripples.length > 0) {
                rippleFrame = window.requestAnimationFrame(tickRipples);
            } else {
                rippleFrame = 0;
                if (!isHovering) startIdle();
            }
        };

        const startRipples = () => {
            if (rippleFrame || !isVisible || isIntroActive()) return;
            stopIdle();
            rippleFrame = window.requestAnimationFrame(tickRipples);
        };

        const updateFromEvent = (event) => {
            if (event.pointerType !== "mouse" || isIntroActive()) return;

            isHovering = true;
            stopIdle();
            if (resumeIdleTimer) {
                window.clearTimeout(resumeIdleTimer);
                resumeIdleTimer = 0;
            }
            if (glowFrame) {
                window.cancelAnimationFrame(glowFrame);
                glowFrame = 0;
            }
            setGlow(1);
            artRect ??= art.getBoundingClientRect();
            nextX = clamp(
                (event.clientX - artRect.left) / artRect.width,
                0,
                1,
            );
            nextY = clamp(
                (event.clientY - artRect.top) / artRect.height,
                0,
                1,
            );
            render(nextX, nextY);
        };

        const fadeGlowOut = () => {
            if (glowFrame || isIntroActive()) return;

            const start = window.performance.now();
            const duration = 240;

            const tick = (now) => {
                const progress = clamp((now - start) / duration, 0, 1);
                setGlow(1 - progress);

                if (progress < 1 && !isHovering) {
                    glowFrame = window.requestAnimationFrame(tick);
                } else {
                    glowFrame = 0;
                }
            };

            glowFrame = window.requestAnimationFrame(tick);
        };

        const rippleFromEvent = (event) => {
            if (!canRipple || event.pointerType === "mouse" || isIntroActive()) {
                return;
            }

            isHovering = false;
            if (renderFrame) {
                window.cancelAnimationFrame(renderFrame);
                renderFrame = 0;
            }
            if (resumeIdleTimer) {
                window.clearTimeout(resumeIdleTimer);
                resumeIdleTimer = 0;
            }
            syncGlowBounds();

            const x = clamp((event.clientX - artRect.left) / artRect.width, 0, 1);
            const y = clamp((event.clientY - artRect.top) / artRect.height, 0, 1);

            nextX = x;
            nextY = y;
            ripples = [{ x, y, startedAt: window.performance.now() }];

            setGlow(0.65);
            fadeGlowOut();
            startRipples();
        };

        if (canFollowPointer) {
            art.addEventListener("pointermove", updateFromEvent);
            art.addEventListener("pointerenter", (event) => {
                if (isIntroActive()) return;
                syncGlowBounds();
                updateFromEvent(event);
            });
            art.addEventListener("pointerleave", () => {
                isHovering = false;
                nextX = centerX;
                nextY = centerY;
                fadeGlowOut();
                scheduleIdleResume();
            });

            art.addEventListener("pointercancel", () => {
                isHovering = false;
                fadeGlowOut();
                scheduleIdleResume();
            });
        }

        art.addEventListener("pointerdown", rippleFromEvent);

        if ("IntersectionObserver" in window) {
            const observer = new IntersectionObserver(
                ([entry]) => {
                    isVisible = entry.isIntersecting;

                    if (isVisible) {
                        syncResponsiveState();
                        if (introRevealProgress < 1) {
                            startIntroReveal();
                        } else {
                            startIdle();
                        }
                    } else {
                        stopIntroReveal();
                        stopIdle();
                        stopRipples();
                    }
                },
                { threshold: 0.05 },
            );

            observer.observe(field);
        }

        setGlow(0);
        startIntroReveal();
    });
</script>

<style>
    .ascii-field {
        position: relative;
        justify-self: center;
        align-self: stretch;
        width: min(100%, 41rem);
        height: calc(100% - clamp(0.85rem, 2vw, 1.75rem));
        margin-block: auto;
    }

    .ascii-field::before {
        content: "";
        position: absolute;
        inset: -10% -6%;
        background:
            radial-gradient(
                circle at 22% 32%,
                color-mix(in srgb, var(--primary) 12%, transparent),
                transparent 44%
            ),
            radial-gradient(
                circle at 74% 24%,
                color-mix(in srgb, var(--secondary) 8%, transparent),
                transparent 38%
            ),
            radial-gradient(
                circle at 52% 66%,
                color-mix(in srgb, var(--warning) 6%, transparent),
                transparent 48%
            );
        filter: blur(20px);
        opacity: 0.16;
        pointer-events: none;
    }

    .ascii-field-surface {
        position: relative;
        width: 100%;
        height: 100%;
        display: grid;
        align-items: center;
        justify-items: center;
        transform: translateY(-0.15rem);
    }

    .ascii-field-glow {
        position: absolute;
        left: 50%;
        top: 50%;
        width: var(--glow-width, 100%);
        height: var(--glow-height, 100%);
        transform: translate(-50%, -50%);
        background:
            radial-gradient(
                circle at var(--field-x, 50%) var(--field-y, 48%),
                color-mix(in srgb, var(--primary) 18%, transparent),
                transparent 34%
            ),
            radial-gradient(
                circle at calc(var(--field-x, 50%) + 8%)
                    calc(var(--field-y, 48%) + 10%),
                color-mix(in srgb, var(--secondary) 11%, transparent),
                transparent 26%
            );
        filter: blur(12px);
        opacity: var(--glow-opacity, 0);
        pointer-events: none;
    }

    .ascii-field[data-intro] .ascii-field-glow {
        opacity: 0 !important;
    }

    .ascii-field-art {
        position: relative;
        margin: 0;
        color: color-mix(in srgb, var(--text-muted) 78%, var(--bg-light));
        font-family: var(--font-mono);
        font-size: 0.4rem;
        line-height: 0.87;
        letter-spacing: 0.006em;
        white-space: pre;
        text-shadow: 0 0 20px color-mix(in srgb, var(--primary) 8%, transparent);
        transform: translate3d(0, 0, 0);
        user-select: none;
        touch-action: manipulation;
        display: inline-block;
        animation: field-breathe 8s var(--ease-out-quart) infinite alternate;
    }

    .ascii-field[data-intro] .ascii-field-art {
        pointer-events: none;
    }

    @media (min-width: 1440px) {
        .ascii-field {
            width: min(100%, 48rem);
            height: calc(100% - 0.35rem);
        }

        .ascii-field-art {
            font-size: 0.47rem;
            line-height: 0.84;
            letter-spacing: 0.004em;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .ascii-field-glow {
            opacity: 0.45;
        }

        .ascii-field-art {
            animation: none;
        }
    }

    @media (max-width: 900px) {
        .ascii-field {
            justify-self: stretch;
            width: 100%;
            height: auto;
            max-height: min(52svh, 32rem);
            margin-block: 0;
            overflow: clip;
        }

        .ascii-field-surface {
            min-height: 0;
        }
    }

    @media (max-width: 640px) {
        .ascii-field {
            max-height: min(43svh, 22rem);
        }

        .ascii-field-art {
            font-size: 0.27rem;
            letter-spacing: 0.005em;
            line-height: 0.93;
            opacity: 0.86;
        }
    }

    @media (max-width: 350px) and (max-height: 775px) {
        .ascii-field {
            height: auto;
            max-height: 39svh;
        }

        .ascii-field-art {
            font-size: 0.265rem;
            line-height: 0.91;
            letter-spacing: 0.004em;
        }
    }

    @keyframes field-breathe {
        from {
            transform: translate3d(-1px, -1px, 0);
        }
        to {
            transform: translate3d(1px, 1px, 0);
        }
    }
</style>
