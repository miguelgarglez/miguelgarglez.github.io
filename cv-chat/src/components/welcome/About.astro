---
const personalNotes = [
    {
        index: "01",
        ascii: "[team]",
        title: "Team rhythm",
        body: "I grew up playing federated football, which shaped how I understand discipline, roles, feedback, and showing up for a group over time.",
    },
    {
        index: "02",
        ascii: "{learn}",
        title: "Learning mode",
        body: "I tend to follow curiosity into tools, interfaces, AI workflows, and implementation details until I can turn them into practical habits.",
    },
    {
        index: "03",
        ascii: "<voice>",
        title: "Communication range",
        body: "I work comfortably across technical and product contexts, with C1 English, public speaking experience, and a preference for clear explanations.",
    },
];
---

<section id="about" class="about">
    <div class="about-shell section-shell">
        <div class="about-heading section-rail">
            <p class="section-kicker">/about</p>
            <h2 class="section-title editorial-title">A Human Layer</h2>
        </div>

        <div class="about-content">
            <div class="about-text">
                <p class="intro">
                    I care about building useful software with people, not just
                    shipping isolated pieces of code.
                </p>
                <p class="description">
                    My engineering taste comes from product work, platform
                    thinking, and a habit of making tools understandable for the
                    teams around them. The professional story is in the next
                    section; this is the quieter layer behind it.
                </p>
            </div>

            <div class="personal-notes" aria-label="Personal notes">
                {
                    personalNotes.map((note) => (
                        <article class="personal-note about-reveal">
                            <div class="note-meta">
                                <span>{note.index}</span>
                                <code>{note.ascii}</code>
                            </div>
                            <h3>{note.title}</h3>
                            <p>{note.body}</p>
                        </article>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<script>
    import {
        getScrollMotionTools,
        prefersReducedMotion,
    } from "../../lib/motion";

    document.addEventListener("DOMContentLoaded", async () => {
        if (prefersReducedMotion()) {
            return;
        }

        const { gsap } = await getScrollMotionTools();

        gsap.set("#about .about-heading", { y: 34, opacity: 0 });
        gsap.set("#about .about-text p", { y: 26, opacity: 0 });
        gsap.set("#about .about-reveal", { y: 34, opacity: 0 });

        gsap.to("#about .about-heading", {
            y: 0,
            opacity: 1,
            duration: 0.72,
            ease: "power3.out",
            scrollTrigger: {
                trigger: "#about",
                start: "top 70%",
                toggleActions: "play none none reverse",
            },
        });

        gsap.to("#about .about-text p", {
            y: 0,
            opacity: 1,
            duration: 0.62,
            stagger: 0.12,
            ease: "power3.out",
            scrollTrigger: {
                trigger: "#about .about-text",
                start: "top 80%",
                toggleActions: "play none none reverse",
            },
        });

        gsap.to("#about .about-reveal", {
            y: 0,
            opacity: 1,
            duration: 0.64,
            stagger: 0.12,
            ease: "power3.out",
            force3D: true,
            scrollTrigger: {
                trigger: "#about .personal-notes",
                start: "top 80%",
                toggleActions: "play none none reverse",
            },
        });
    });
</script>

<style>
    .about {
        position: relative;
        padding: clamp(4.5rem, 9vw, 7rem) 1.25rem;
        background: var(--bg);
        color: var(--text);
        overflow: clip;
    }

    .about::before {
        content: "";
        position: absolute;
        inset: auto 0 0;
        height: 1px;
        background: linear-gradient(
            90deg,
            transparent,
            color-mix(in srgb, var(--border) 70%, transparent),
            transparent
        );
    }

    .about-shell {
        --section-rail-min: 220px;
    }

    .note-meta {
        font-family: var(--font-mono);
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .about-content {
        display: grid;
        gap: clamp(2rem, 4vw, 3.25rem);
        min-width: 0;
    }

    .about-text {
        max-width: 52rem;
    }

    .intro {
        margin: 0;
        color: var(--text);
        font-family: var(--font-display);
        font-size: clamp(1.7rem, 3vw, 3.1rem);
        line-height: 1.04;
        letter-spacing: -0.045em;
    }

    .description {
        max-width: 42rem;
        margin: 1.35rem 0 0;
        color: var(--text-muted);
        font-size: clamp(1rem, 1.35vw, 1.15rem);
        line-height: 1.75;
    }

    .personal-notes {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
    }

    .personal-note {
        min-height: 16rem;
        padding: clamp(1.25rem, 2.4vw, 1.85rem);
        background: linear-gradient(
            180deg,
            color-mix(in srgb, var(--bg-light) 92%, transparent),
            color-mix(in srgb, var(--bg) 96%, transparent)
        );
        will-change: transform, opacity;
    }

    .note-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        color: color-mix(in srgb, var(--primary) 78%, var(--text-muted));
        font-size: 0.72rem;
    }

    .note-meta code {
        color: var(--text-subtle, var(--text-muted));
        font-family: var(--font-mono);
        font-size: 0.72rem;
        text-transform: none;
    }

    .personal-note h3 {
        margin: clamp(2.4rem, 5vw, 4.25rem) 0 0.9rem;
        color: var(--text);
        font-family: var(--font-display);
        font-size: clamp(1.35rem, 2vw, 1.8rem);
        line-height: 1.05;
        letter-spacing: -0.045em;
    }

    .personal-note p {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.98rem;
        line-height: 1.65;
    }

    .personal-note:hover {
        background: linear-gradient(
            180deg,
            color-mix(in srgb, var(--primary) 8%, var(--bg-light)),
            color-mix(in srgb, var(--bg) 96%, transparent)
        );
    }

    @media (max-width: 1023px) {
        .about-shell {
            grid-template-columns: 1fr;
        }

        .about-heading {
            max-width: 36rem;
            padding-right: 0;
            border-right: 0;
        }
    }

    @media (max-width: 768px) {
        .about {
            padding: 4rem 1rem;
        }

        .personal-notes {
            grid-template-columns: 1fr;
        }

        .personal-note {
            min-height: auto;
        }

        .personal-note h3 {
            margin-top: 2.4rem;
        }
    }
</style>
