<script>
    import {
        getScrollMotionTools,
        prefersReducedMotion,
    } from "../../lib/motion";

    document.addEventListener("DOMContentLoaded", async () => {
        const cards = Array.from(
            document.querySelectorAll("#skills .skill-card"),
        );
        const supportsHover = window.matchMedia(
            "(hover: hover) and (pointer: fine)",
        ).matches;

        const setActiveCard = (card) => {
            cards.forEach((item) => {
                item.classList.remove("is-active");
                item.setAttribute("aria-expanded", "false");
            });
            card.classList.add("is-active");
            card.setAttribute("aria-expanded", "true");
        };

        cards.forEach((card) => {
            card.addEventListener("focusin", () => setActiveCard(card));
            card.addEventListener("keydown", (event) => {
                if (event.key === "Enter" || event.key === " ") {
                    event.preventDefault();
                    setActiveCard(card);
                }
            });

            if (supportsHover) {
                card.addEventListener("mouseenter", () => setActiveCard(card));
            } else {
                card.addEventListener("click", () => setActiveCard(card));
            }
        });

        if (prefersReducedMotion()) {
            return;
        }

        const { gsap } = await getScrollMotionTools();

        gsap.set("#skills .section-title", { y: 50, opacity: 0 });
        gsap.set("#skills .skill-card", { y: 56, opacity: 0 });
        gsap.set("#skills .philosophy-reveal", {
            y: 36,
            scale: 0.96,
            opacity: 0,
        });

        gsap.to("#skills .section-title", {
            y: 0,
            opacity: 1,
            duration: 1,
            ease: "power2.out",
            scrollTrigger: {
                trigger: "#skills",
                start: "top 70%",
                end: "bottom 70%",
                toggleActions: "play none none reverse",
            },
        });

        gsap.to("#skills .skill-card", {
            y: 0,
            opacity: 1,
            duration: 0.72,
            stagger: 0.12,
            ease: "power3.out",
            force3D: true,
            scrollTrigger: {
                trigger: "#skills .skills-disclosure",
                start: "top 80%",
                end: "bottom 80%",
                toggleActions: "play none none reverse",
            },
        });

        gsap.to("#skills .philosophy-reveal", {
            y: 0,
            scale: 1,
            opacity: 1,
            duration: 0.8,
            ease: "power3.out",
            force3D: true,
            scrollTrigger: {
                trigger: "#skills .philosophy",
                start: "top 80%",
                end: "bottom 80%",
                toggleActions: "play none none reverse",
            },
        });
    });
</script>

