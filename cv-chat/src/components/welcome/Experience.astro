---
import { Icon } from "astro-icon/components";

const workNotes = [
    {
        index: "01",
        title: "Design systems at scale",
        body: "Reusable UI infrastructure, Storybook documentation, accessibility practices, release workflows, and component quality for frontend teams.",
        prompt: "Explain Miguel's design system experience",
    },
    {
        index: "02",
        title: "AI-assisted engineering",
        body: "Using coding agents, MCP servers, context engineering, and structured prompts to move faster without losing code ownership.",
        prompt: "How does Miguel use AI in engineering?",
    },
    {
        index: "03",
        title: "Product-minded delivery",
        body: "Balancing technical quality, maintainability, team adoption, UX, and business value across product-facing engineering work.",
        prompt: "Summarize Miguel's work style",
    },
    {
        index: "04",
        title: "Cross-team collaboration",
        body: "Supporting developers through components, documentation, conventions, agile coordination, and practical implementation guidance.",
        prompt: "What makes Miguel a strong frontend platform engineer?",
    },
];

const roles = [
    {
        status: "current role",
        period: "Sep 2024 - Current",
        title: "Frontend UI Platform Engineer",
        company: "Open Digital Services (Santander Group)",
        summary:
            "Building and maintaining UI components for frontend teams across Grupo Santander.",
        tags: [
            "Design systems",
            "Accessibility",
            "Storybook",
            "Release workflows",
            "Semantic versioning",
            "AI-assisted development",
        ],
        achievements: [
            "Member of the Kubit Web UI components platform team, building and maintaining the component library used by web developers across Grupo Santander banks.",
            "Lead implementation, maintenance, and refactoring of UI components, ensuring consistency, performance, and accessibility across the product ecosystem.",
            "Contribute to the open-source charting library, adding new features and continuous improvements.",
            "Manage releases with semantic versioning, branch strategy, and Storybook documentation; support Kubit's public presence through product landing pages.",
            "Built an MCP server to support consumers of the component library with contextual guidance, integration patterns, troubleshooting, and migration help.",
            "Drive AI-enabled workflows with tools like GitHub Copilot, MCP servers, and context engineering to improve productivity, code quality, and collaborative development.",
        ],
        prompt: "What has Miguel built at Santander?",
    },
    {
        status: "quality foundation",
        period: "Sep 2023 - Jul 2024",
        title: "QA Software Engineer",
        company: "Jember Engineering Solutions",
        summary:
            "Worked close to product quality, validation, and delivery, strengthening attention to detail, reliability, and user-facing impact.",
        tags: [
            "Quality mindset",
            "Testing",
            "Product validation",
            "Agile coordination",
            "Automation recovery",
        ],
        achievements: [
            "Worked and coordinated with the app frontend development team using agile methodologies, keeping different parties aligned to successfully complete new features.",
            "Reported hundreds of bugs, leading to noticeable improvements on the app's performance and UX.",
            "Worked with another QA to refactor and relaunch a test automation project for company apps that had been abandoned for more than 2 years, leading to a 50% improvement in person-day cost for regression tests.",
        ],
        prompt: "Summarize Miguel's QA background",
    },
    {
        status: "early delivery",
        period: "Jan 2022 - May 2022",
        title: "Software Developer",
        company: "Electric-Save",
        summary:
            "Early-stage B2B software work across customer support, product demos, and web application delivery.",
        tags: [
            "B2B product",
            "Client communication",
            "Proof of concept",
            "Remote demos",
            "Software support",
        ],
        achievements: [
            "Attended clients directly in a B2B startup context, reporting and fixing errors with the company's software and contributing to customer satisfaction and continuity.",
            "Created a web application proof of concept for an important potential client, moving the proposal to the next selection stage.",
            "Ran remote meetings to show the software product to new potential clients, opening new challenges and growth opportunities for the company.",
        ],
        prompt: "How did Miguel's early role shape his product mindset?",
    },
];
---

<section id="experience" class="experience" aria-labelledby="experience-title">
    <div class="experience-shell section-shell">
        <aside
            class="dossier-index section-rail"
            aria-label="Experience dossier index"
        >
            <p class="section-kicker">/experience</p>
            <h2 id="experience-title" class="editorial-title">Working Notes</h2>
            <p>
                Four working patterns that show up across my roles: systems
                thinking, AI leverage, product judgment, and team enablement.
            </p>
        </aside>

        <div class="experience-content">
            <div class="notes-grid" aria-label="Working notes">
                {
                    workNotes.map((note) => (
                        <article class="note-card dossier-reveal">
                            <span class="note-index">{note.index}</span>
                            <h3>{note.title}</h3>
                            <p>{note.body}</p>
                            <button
                                class="agent-link"
                                type="button"
                                data-chat-prompt={note.prompt}
                            >
                                <span>Ask the agent</span>
                                <Icon
                                    name="lucide:arrow-up-right"
                                    aria-hidden="true"
                                />
                            </button>
                        </article>
                    ))
                }
            </div>

            <div class="role-stack" aria-label="Professional experience">
                <div class="role-stack-heading dossier-reveal">
                    <p class="section-kicker">/role_archive</p>
                    <h3>Roles</h3>
                </div>

                {
                    roles.map((role, roleIndex) => (
                        <article
                            class={`role-card dossier-reveal ${roleIndex === 0 ? "current" : ""}`}
                        >
                            <header class="role-header">
                                <div>
                                    <p class="role-status">{role.status}</p>
                                    <h4>{role.title}</h4>
                                    <p class="role-company">{role.company}</p>
                                </div>
                                <p class="role-period">{role.period}</p>
                            </header>

                            <p class="role-summary">{role.summary}</p>

                            <div
                                class="role-tags"
                                aria-label={`${role.title} focus areas`}
                            >
                                {role.tags.map((tag) => (
                                    <span>{tag}</span>
                                ))}
                            </div>

                            <button
                                class="expand-btn"
                                type="button"
                                aria-expanded={
                                    roleIndex === 0 ? "true" : "false"
                                }
                                aria-controls={`experience-achievements-${roleIndex + 1}`}
                            >
                                <span class="expand-text">
                                    {roleIndex === 0
                                        ? "Show less"
                                        : "Show details"}
                                </span>
                                <span class="expand-icon" aria-hidden="true">
                                    {roleIndex === 0 ? "-" : "+"}
                                </span>
                            </button>

                            <ul
                                class={`achievements ${roleIndex === 0 ? "expanded" : ""}`}
                                id={`experience-achievements-${roleIndex + 1}`}
                            >
                                {role.achievements.map((achievement) => (
                                    <li>{achievement}</li>
                                ))}
                            </ul>

                            <button
                                class="agent-link role-prompt"
                                type="button"
                                data-chat-prompt={role.prompt}
                            >
                                <span>{role.prompt}</span>
                                <Icon
                                    name="lucide:arrow-up-right"
                                    aria-hidden="true"
                                />
                            </button>
                        </article>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<script>
    import {
        getScrollMotionTools,
        prefersReducedMotion,
    } from "../../lib/motion";

    document.addEventListener("DOMContentLoaded", async () => {
        const expandBtns = document.querySelectorAll("#experience .expand-btn");

        expandBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const achievements = btn.nextElementSibling;
                const expandText = btn.querySelector(".expand-text");
                const expandIcon = btn.querySelector(".expand-icon");
                if (!(achievements instanceof HTMLElement)) return;
                if (!expandText) return;
                if (!expandIcon) return;

                const nextExpanded =
                    !achievements.classList.contains("expanded");

                achievements.classList.toggle("expanded", nextExpanded);
                btn.classList.toggle("expanded", nextExpanded);
                btn.setAttribute("aria-expanded", String(nextExpanded));
                expandText.textContent = nextExpanded
                    ? "Show less"
                    : "Show details";
                expandIcon.textContent = nextExpanded ? "-" : "+";
            });
        });

        document
            .querySelectorAll("#experience [data-chat-prompt]")
            .forEach((button) => {
                button.addEventListener("click", () => {
                    const prompt =
                        button.getAttribute("data-chat-prompt") ?? "";
                    window.dispatchEvent(new CustomEvent("cv-chat:open"));
                    window.dispatchEvent(
                        new CustomEvent("cv-chat:prompt", {
                            detail: { prompt },
                        }),
                    );
                });
            });

        if (prefersReducedMotion()) {
            return;
        }

        const { gsap } = await getScrollMotionTools();

        gsap.set("#experience .dossier-index", { y: 28, opacity: 0 });
        gsap.set("#experience .dossier-reveal", { y: 36, opacity: 0 });

        gsap.to("#experience .dossier-index", {
            y: 0,
            opacity: 1,
            duration: 0.72,
            ease: "power3.out",
            scrollTrigger: {
                trigger: "#experience",
                start: "top 72%",
                toggleActions: "play none none reverse",
            },
        });

        gsap.to("#experience .dossier-reveal", {
            y: 0,
            opacity: 1,
            duration: 0.68,
            stagger: 0.08,
            ease: "power3.out",
            scrollTrigger: {
                trigger: "#experience .experience-content",
                start: "top 78%",
                toggleActions: "play none none reverse",
            },
        });
    });
</script>

<style>
    .experience {
        position: relative;
        padding: clamp(4.5rem, 9vw, 8rem) 1.25rem;
        color: var(--text);
        overflow: clip;
    }

    .experience::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            linear-gradient(
                90deg,
                color-mix(in srgb, var(--border) 34%, transparent) 1px,
                transparent 1px
            ),
            linear-gradient(
                180deg,
                color-mix(in srgb, var(--border) 28%, transparent) 1px,
                transparent 1px
            );
        background-size: 96px 96px;
        mask-image: linear-gradient(
            180deg,
            transparent,
            black 16%,
            black 82%,
            transparent
        );
        opacity: 0.18;
        pointer-events: none;
    }

    .experience-shell {
        position: relative;
        z-index: 1;
    }

    .dossier-index {
        position: sticky;
        top: 7rem;
        align-self: start;
    }

    .note-index,
    .role-status,
    .role-period,
    .agent-link {
        font-family: var(--font-mono);
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .note-index,
    .role-status {
        margin: 0;
        color: var(--primary);
        font-size: 0.72rem;
    }

    .dossier-index h2 {
        margin-bottom: 1rem;
    }

    .dossier-index p:not(.section-kicker) {
        margin: 0;
        color: var(--text-muted);
        font-size: clamp(1rem, 1.4vw, 1.15rem);
        line-height: 1.7;
    }

    .experience-content {
        display: grid;
        gap: clamp(3rem, 6vw, 5rem);
        min-width: 0;
    }

    .notes-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
    }

    .note-card,
    .role-card {
        background: linear-gradient(
            180deg,
            color-mix(in srgb, var(--bg-light) 88%, transparent),
            color-mix(in srgb, var(--bg) 96%, transparent)
        );
    }

    .note-card {
        position: relative;
        min-height: 17rem;
        padding: clamp(1.35rem, 2.5vw, 2rem);
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .note-index {
        position: absolute;
        top: clamp(1rem, 2vw, 1.45rem);
        right: clamp(1rem, 2vw, 1.45rem);
        color: color-mix(in srgb, var(--primary) 72%, var(--text-muted));
        font-size: 0.78rem;
    }

    .note-card h3 {
        max-width: 12ch;
        margin: 1.8rem 0 1rem;
        font-size: clamp(1.45rem, 2.4vw, 2.1rem);
        line-height: 1.02;
    }

    .note-card p {
        margin: 0 0 1.5rem;
        color: var(--text-muted);
        line-height: 1.65;
    }

    .agent-link {
        margin-top: auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        min-height: 2.35rem;
        padding: 0.1rem 0;
        border: 0;
        border-bottom: 1px solid
            color-mix(in srgb, var(--primary) 45%, transparent);
        background: transparent;
        color: var(--text);
        font-size: 0.7rem;
        cursor: pointer;
        transition:
            color 180ms ease,
            border-color 180ms ease,
            transform 180ms var(--ease-out-quart);
    }

    .agent-link svg {
        width: 0.85rem;
        height: 0.85rem;
        color: var(--primary);
        transition: transform 180ms var(--ease-out-quart);
    }

    @media (hover: hover) and (pointer: fine) {
        .agent-link:hover {
            color: var(--primary);
            transform: translateY(-1px);
        }

        .agent-link:hover svg {
            transform: translate(2px, -2px);
        }
    }

    .agent-link:active,
    .expand-btn:active {
        transform: scale(0.97);
    }

    .agent-link:hover {
        border-color: var(--primary);
    }

    .agent-link:focus-visible,
    .expand-btn:focus-visible {
        outline: none;
        box-shadow: 0 0 0 3px
            color-mix(in srgb, var(--primary) 24%, transparent);
    }

    .role-stack {
        display: grid;
        gap: 1rem;
    }

    .role-stack-heading {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.5rem;
    }

    .role-stack-heading h3 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3.6rem);
        line-height: 1;
    }

    .role-card {
        position: relative;
        padding: clamp(1.4rem, 3vw, 2.35rem);
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .role-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto;
        height: 2px;
        background: linear-gradient(90deg, var(--primary), transparent 62%);
        opacity: 0;
    }

    .role-card.current::before {
        opacity: 1;
    }

    .role-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1.5rem;
        align-items: start;
    }

    .role-card h4 {
        margin: 0.55rem 0 0.35rem;
        font-size: clamp(1.55rem, 3vw, 2.55rem);
        line-height: 1.04;
    }

    .role-company,
    .role-summary,
    .achievements {
        color: var(--text-muted);
    }

    .role-company {
        margin: 0;
        font-size: 1rem;
    }

    .role-period {
        margin: 0;
        color: var(--text);
        font-size: 0.76rem;
        text-align: right;
        white-space: nowrap;
    }

    .role-summary {
        max-width: 44rem;
        margin: 1.5rem 0 1.2rem;
        font-size: 1.06rem;
        line-height: 1.7;
    }

    .role-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-bottom: 1.35rem;
    }

    .role-tags span {
        display: inline-flex;
        border: 1px solid var(--border-muted);
        border-radius: 999px;
        padding: 0.38rem 0.65rem;
        color: var(--text-muted);
        font-family: var(--font-mono);
        font-size: 0.72rem;
    }

    .expand-btn {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        min-height: 2.4rem;
        padding: 0.58rem 0.9rem;
        border: 1px solid color-mix(in srgb, var(--primary) 48%, var(--border));
        border-radius: 999px;
        background: color-mix(in srgb, var(--primary) 10%, transparent);
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 0.76rem;
        cursor: pointer;
        box-shadow: inset 0 0 0 1px
            color-mix(in srgb, var(--primary) 8%, transparent);
        transition:
            background-color 180ms ease,
            border-color 180ms ease,
            box-shadow 180ms ease,
            transform 160ms var(--ease-out-quart);
    }

    @media (hover: hover) and (pointer: fine) {
        .expand-btn:hover {
            border-color: color-mix(in srgb, var(--primary) 72%, var(--border));
            background: color-mix(in srgb, var(--primary) 14%, transparent);
            box-shadow:
                inset 0 0 0 1px
                    color-mix(in srgb, var(--primary) 14%, transparent),
                0 0 24px color-mix(in srgb, var(--primary) 10%, transparent);
        }
    }

    .expand-icon {
        display: inline-grid;
        width: 1rem;
        place-items: center;
        color: var(--primary);
        font-weight: 700;
    }

    .achievements {
        display: grid;
        gap: 0.85rem;
        list-style: none;
        margin: 0;
        padding: 0;
        max-width: 48rem;
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        transition:
            max-height 280ms cubic-bezier(0.23, 1, 0.32, 1),
            opacity 180ms ease,
            margin-top 280ms cubic-bezier(0.23, 1, 0.32, 1);
    }

    .achievements.expanded {
        margin-top: 1.35rem;
        max-height: 34rem;
        opacity: 1;
    }

    .achievements li {
        position: relative;
        padding-left: 1.1rem;
        line-height: 1.65;
    }

    .achievements li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.7rem;
        width: 0.34rem;
        height: 0.34rem;
        border-radius: 999px;
        background: var(--primary);
    }

    .role-prompt {
        margin-top: 1.35rem;
        max-width: 100%;
        text-align: left;
        justify-content: flex-start;
    }

    body.light .experience::before {
        opacity: 0.24;
    }

    body.light .note-card,
    body.light .role-card {
        background: linear-gradient(
            180deg,
            color-mix(in srgb, var(--bg-light) 92%, transparent),
            color-mix(in srgb, var(--bg) 95%, transparent)
        );
    }

    @media (max-width: 980px) {
        .experience-shell {
            grid-template-columns: 1fr;
        }

        .dossier-index {
            position: relative;
            top: auto;
            min-height: 0;
            padding-right: 0;
            padding-bottom: 2rem;
            border-right: 0;
            border-bottom: 1px solid var(--border);
        }
    }

    @media (max-width: 720px) {
        .experience {
            padding: 4rem 1rem;
        }

        .notes-grid {
            grid-template-columns: 1fr;
        }

        .note-card {
            min-height: 14rem;
        }

        .role-stack-heading {
            display: grid;
            align-items: start;
        }

        .role-header {
            grid-template-columns: 1fr;
            gap: 0.9rem;
        }

        .role-period {
            text-align: left;
            white-space: normal;
        }

        .role-prompt {
            width: 100%;
            justify-content: flex-start;
            line-height: 1.4;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .agent-link,
        .expand-btn {
            transition: none;
        }

        .achievements {
            transition: opacity 160ms ease;
        }
    }
</style>
