---
import { Icon } from 'astro-icon/components';
---

<section id="contact" class="contact">
  <div class="container">
    <div class="section-heading">
      <p class="section-kicker">/contact</p>
      <h2 class="section-title editorial-title">Let's Connect</h2>
      <p class="section-copy">
        Open to product-minded engineering conversations, frontend platform
        work, and thoughtful teams building useful software.
      </p>
    </div>

    <div class="contact-content">
      <div class="contact-info">
        <p class="panel-index">01</p>
        <h3>Get in Touch</h3>
        <p class="contact-description">
          The fastest way to reach me is through LinkedIn. I also keep X around
          for software notes, tools, and the occasional build log.
        </p>

        <div class="contact-methods">
          <div class="contact-method-reveal">
            <a
              href="https://www.linkedin.com/in/miguel-garciag"
              target="_blank"
              rel="noreferrer"
              class="contact-method"
            >
              <Icon
                class="method-icon"
                name="lucide:linkedin"
                aria-hidden="true"
              />
              <div class="method-content">
                <span class="method-label">LinkedIn</span>
                <span class="method-value">miguel-garciag</span>
              </div>
            </a>
          </div>

          <div class="contact-method-reveal">
            <a
              href="https://x.com/miguel_garglez"
              target="_blank"
              rel="noreferrer"
              class="contact-method"
            >
              <Icon
                class="method-icon method-icon-solid"
                name="simple-icons:x"
                aria-hidden="true"
              />
              <div class="method-content">
                <span class="method-label">X (Twitter)</span>
                <span class="method-value">miguel_garglez</span>
              </div>
            </a>
          </div>
        </div>
      </div>

      <div class="hobbies-section">
        <p class="panel-index">02</p>
        <h3>Beyond Code</h3>
        <div class="hobbies">
          <div class="hobby-item-reveal">
            <div class="hobby-item">
              <Icon class="hobby-icon" name="lucide:trophy" aria-hidden="true" />
              <div class="hobby-text">
                <h4>Team Sports</h4>
                <p>
                  Playing football since age seven, passionate about physical
                  well-being and team sports.
                </p>
              </div>
            </div>
          </div>

          <div class="hobby-item-reveal">
            <div class="hobby-item">
              <Icon class="hobby-icon" name="lucide:cpu" aria-hidden="true" />
              <div class="hobby-text">
                <h4>Technical Curiosity</h4>
                <p>
                  Regular reader of software engineering blogs, always eager to
                  learn about new technologies and innovations.
                </p>
              </div>
            </div>
          </div>

          <div class="hobby-item-reveal">
            <div class="hobby-item">
              <Icon
                class="hobby-icon"
                name="lucide:sparkles"
                aria-hidden="true"
              />
              <div class="hobby-text">
                <h4>Deliberate Growth</h4>
                <p>
                  Always seeking new activities that push me out of my comfort
                  zone and help me grow as a person.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { getScrollMotionTools, prefersReducedMotion } from '../../lib/motion';

  document.addEventListener('DOMContentLoaded', async () => {
    if (prefersReducedMotion()) {
      return;
    }

    const { gsap } = await getScrollMotionTools();

    gsap.set('#contact .section-heading', { y: 44, opacity: 0 });
    gsap.set('#contact .contact-info', { y: 42, opacity: 0 });
    gsap.set('#contact .contact-method-reveal', { y: 20, opacity: 0 });
    gsap.set('#contact .hobbies-section', { y: 42, opacity: 0 });
    gsap.set('#contact .hobby-item-reveal', { y: 20, opacity: 0 });

    gsap.to('#contact .section-heading', {
      y: 0,
      opacity: 1,
      duration: 0.72,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#contact',
        start: 'top 70%',
        end: 'bottom 70%',
        toggleActions: 'play none none reverse',
      },
    });

    gsap.to('#contact .contact-info', {
      y: 0,
      opacity: 1,
      duration: 0.62,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#contact .contact-content',
        start: 'top 80%',
        end: 'bottom 80%',
        toggleActions: 'play none none reverse',
      },
    });

    gsap.to('#contact .contact-method-reveal', {
      y: 0,
      opacity: 1,
      duration: 0.5,
      stagger: 0.08,
      ease: 'power3.out',
      force3D: true,
      scrollTrigger: {
        trigger: '#contact .contact-methods',
        start: 'top 85%',
        end: 'bottom 85%',
        toggleActions: 'play none none reverse',
      },
    });

    gsap.to('#contact .hobbies-section', {
      y: 0,
      opacity: 1,
      duration: 0.62,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#contact .contact-content',
        start: 'top 80%',
        end: 'bottom 80%',
        toggleActions: 'play none none reverse',
      },
    });

    gsap.to('#contact .hobby-item-reveal', {
      y: 0,
      opacity: 1,
      duration: 0.5,
      stagger: 0.08,
      ease: 'power3.out',
      force3D: true,
      scrollTrigger: {
        trigger: '#contact .hobbies',
        start: 'top 85%',
        end: 'bottom 85%',
        toggleActions: 'play none none reverse',
      },
    });
  });
</script>

<style>
  .contact {
    padding: clamp(4.5rem, 9vw, 7rem) 1.25rem;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg-light) 45%, transparent),
        var(--bg) 34%
      );
    color: var(--text);
    overflow: hidden;
    position: relative;
  }

  .contact::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--border) 34%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--border) 22%, transparent) 1px,
        transparent 1px
      );
    background-size: 96px 96px;
    mask-image: linear-gradient(180deg, transparent, black 18%, black 82%, transparent);
    opacity: 0.14;
    pointer-events: none;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  .section-heading {
    max-width: 760px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .section-copy {
    max-width: 58ch;
    margin: 1.15rem auto 0;
    color: var(--text-muted);
    font-size: clamp(1rem, 1.35vw, 1.1rem);
    line-height: 1.7;
  }

  .contact-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
  }

  .contact-info,
  .hobbies-section {
    border: 1px solid var(--border);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg-light) 88%, transparent),
        color-mix(in srgb, var(--bg) 96%, transparent)
      );
    padding: clamp(1.5rem, 3vw, 2rem);
    min-width: 0;
  }

  .hobbies-section {
    border-left-width: 0;
  }

  .panel-index {
    margin: 0 0 2rem;
    color: var(--primary);
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  .contact-info h3,
  .hobbies-section h3 {
    font-family: var(--font-mono, monospace);
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    color: var(--text);
    margin: 0 0 1rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .contact-description {
    max-width: 42rem;
    font-size: clamp(1rem, 1.35vw, 1.12rem);
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 2rem;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .contact-method-reveal,
  .hobby-item-reveal {
    display: block;
    will-change: transform, opacity;
  }

  .contact-method {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.15rem 1.25rem;
    background: var(--bg);
    border-radius: 0;
    border: 1px solid var(--border-muted);
    border-top-width: 0;
    text-decoration: none;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      transform 160ms var(--ease-out-quart);
  }

  .contact-method-reveal:first-child .contact-method {
    border-top-width: 1px;
  }

  @media (hover: hover) and (pointer: fine) {
    .contact-method:hover,
    .hobby-item:hover {
      background: color-mix(in srgb, var(--bg-light) 92%, var(--primary) 8%);
      border-color: color-mix(in srgb, var(--primary) 38%, var(--border));
    }

    .contact-method:hover {
      transform: translateY(-2px);
    }

    .hobby-item:hover {
      transform: translateX(4px);
    }
  }

  .contact-method:active {
    transform: scale(0.985);
  }

  .contact-method:focus-visible {
    outline: none;
    border-color: var(--focus-ring);
    box-shadow: 0 0 0 3px var(--focus-ring-soft);
  }

  .method-icon {
    width: 1.65rem;
    height: 1.65rem;
    color: var(--primary);
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .method-icon-solid {
    fill: currentColor;
    stroke: none;
  }

  .method-content {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .method-label {
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    color: var(--text-muted);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .method-value {
    font-size: 1.05rem;
    color: var(--text);
    font-weight: 500;
  }

  .hobbies {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hobby-item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.15rem 1.25rem;
    background: var(--bg);
    border-radius: 0;
    border: 1px solid var(--border-muted);
    border-top-width: 0;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      transform 160ms var(--ease-out-quart);
  }

  .hobby-item-reveal:first-child .hobby-item {
    border-top-width: 1px;
  }

  .hobby-icon {
    width: 1.65rem;
    height: 1.65rem;
    flex-shrink: 0;
    color: var(--primary);
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .hobby-text h4 {
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    color: var(--text);
    margin: 0 0 0.45rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hobby-text p {
    font-size: 0.98rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 900px) {
    .contact-content {
      grid-template-columns: 1fr;
    }

    .hobbies-section {
      border-left-width: 1px;
      border-top-width: 0;
    }
  }

  @media (max-width: 768px) {
    .contact {
      padding: 3.5rem 1rem;
    }

    .section-heading {
      margin-bottom: 2rem;
      text-align: left;
    }

    .contact-method,
    .hobby-item {
      padding: 1rem 0;
      border-right-width: 0;
      border-left-width: 0;
      background: transparent;
    }

    .hobby-item {
      align-items: flex-start;
      text-align: left;
    }

    .hobby-icon {
      width: 1.55rem;
      height: 1.55rem;
    }

    .contact-info,
    .hobbies-section {
      padding: 1.15rem 0;
      border-right-width: 0;
      border-left-width: 0;
      background: transparent;
    }

    .contact-description,
    .hobby-text p {
      font-size: 0.95rem;
      line-height: 1.58;
    }
  }
</style>
