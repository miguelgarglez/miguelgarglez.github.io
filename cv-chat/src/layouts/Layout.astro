---
import ThemeToggle from '../components/ThemeToggle.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Miguel García's digital CV. Frontend platform engineer focused on accessible interfaces, scalable design systems, and practical AI workflows."
    />
    <meta name="theme-color" content="#09111c" />
    <link rel="icon" type="image/png" href="/cv-chat/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
    />

    <title>Miguel García</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <ThemeToggle />
    <slot />
  </body>
</html>

<script is:inline>
  const themeMediaQuery = window.matchMedia('(prefers-color-scheme: light)');
  const themeColorMeta = document.querySelector('meta[name="theme-color"]');

  const applyTheme = (theme) => {
    const isLight = theme === 'light';
    document.body.classList.toggle('light', isLight);
    document.documentElement.style.colorScheme = isLight ? 'light' : 'dark';

    if (themeColorMeta) {
      themeColorMeta.setAttribute('content', isLight ? '#f5efe5' : '#09111c');
    }
  };

  const getPreferredTheme = () => {
    const storedTheme = localStorage.getItem('miguel-theme');

    if (storedTheme === 'light' || storedTheme === 'dark') {
      return storedTheme;
    }

    return themeMediaQuery.matches ? 'light' : 'dark';
  };

  applyTheme(getPreferredTheme());

  window['__setPreferredTheme'] = (theme) => {
    localStorage.setItem('miguel-theme', theme);
    applyTheme(theme);
  };

  themeMediaQuery.addEventListener('change', (event) => {
    if (!localStorage.getItem('miguel-theme')) {
      applyTheme(event.matches ? 'light' : 'dark');
    }
  });
</script>

<style>
  html {
    color-scheme: dark;
    scroll-behavior: smooth;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
  }
  * {
    box-sizing: border-box;
  }

  /* Asegurar que ningún elemento cause scroll horizontal */
  body {
    max-width: 100vw;
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    overflow-x: hidden;
    -webkit-tap-highlight-color: rgba(217, 139, 20, 0.18);
    text-rendering: optimizeLegibility;
  }

  :root {
    --font-body: 'Space Grotesk', 'Helvetica Neue', Arial, sans-serif;
    --font-display:
      'Sora', 'Space Grotesk', 'Helvetica Neue', Arial, sans-serif;
    --bg-dark: #050b14;
    --bg: #09111c;
    --bg-light: #101b2b;
    --text: #edf2ff;
    --text-muted: #9ea8bb;
    --highlight: #162338;
    --border: #22324a;
    --border-muted: #152133;
    --primary: #d98b14;
    --secondary: #76bfff;
    --danger: #e66b6b;
    --warning: #f2c84b;
    --success: #5bd69f;
    --info: #78b0ff;
    --ease-out-quart: cubic-bezier(0.165, 0.84, 0.44, 1);
    --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
    --radius-sm: 10px;
    --radius-md: 14px;
    --radius-lg: 20px;
    --shadow-soft: 0 18px 50px rgba(0, 0, 0, 0.35);
    --shadow-card: 0 14px 30px rgba(0, 0, 0, 0.2);
    --shadow-glow: 0 0 40px rgba(242, 169, 59, 0.2);
    --container-max: 1120px;
    --radius: var(--radius-md);
    --background: var(--bg);
    --foreground: var(--text);
    --card: var(--bg-light);
    --card-foreground: var(--text);
    --popover: var(--bg-light);
    --popover-foreground: var(--text);
    --primary-foreground: var(--bg-dark);
    --secondary-foreground: var(--text);
    --muted: var(--highlight);
    --muted-foreground: var(--text-muted);
    --accent: var(--secondary);
    --accent-foreground: var(--bg-dark);
    --destructive: var(--danger);
    --input: var(--border-muted);
    --ring: var(--primary);
  }
  body.light {
    --bg-dark: #ebe3d5;
    --bg: #f5efe5;
    --bg-light: #fffaf3;
    --text: #171513;
    --text-muted: #5e584f;
    --highlight: #e9dfd1;
    --border: #dacdbd;
    --border-muted: #e9dece;
    --primary: #b8740b;
    --secondary: #2e74b8;
    --danger: #b54343;
    --warning: #b9860c;
    --success: #2f8a61;
    --info: #2d6ab7;
    --ease-out-quart: cubic-bezier(0.165, 0.84, 0.44, 1);
    --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
    --shadow-soft: 0 18px 50px rgba(69, 50, 30, 0.15);
    --shadow-card: 0 14px 30px rgba(69, 50, 30, 0.12);
    --shadow-glow: 0 0 30px rgba(176, 106, 6, 0.18);
    --background: var(--bg);
    --foreground: var(--text);
    --card: var(--bg-light);
    --card-foreground: var(--text);
    --popover: var(--bg-light);
    --popover-foreground: var(--text);
    --primary-foreground: var(--bg-dark);
    --secondary-foreground: var(--text);
    --muted: var(--highlight);
    --muted-foreground: var(--text-muted);
    --accent: var(--secondary);
    --accent-foreground: var(--bg-dark);
    --destructive: var(--danger);
    --input: var(--border-muted);
    --ring: var(--primary);
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(
        circle at 15% 20%,
        color-mix(in srgb, var(--primary) 12%, transparent),
        transparent 32%
      ),
      radial-gradient(
        circle at 82% 14%,
        color-mix(in srgb, var(--secondary) 9%, transparent),
        transparent 28%
      ),
      linear-gradient(180deg, color-mix(in srgb, var(--bg-dark) 60%, transparent), transparent 24%);
    pointer-events: none;
    z-index: -1;
  }

  main[id],
  section[id] {
    scroll-margin-top: 96px;
  }

  h1,
  h2,
  h3,
  h4 {
    text-wrap: balance;
  }

  p,
  li {
    text-wrap: pretty;
  }

  a,
  button {
    touch-action: manipulation;
  }

  .skip-link {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 10000;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    background: var(--bg-light);
    color: var(--text);
    border: 1px solid var(--border);
    text-decoration: none;
    transform: translateY(-140%);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
    box-shadow: var(--shadow-card);
    pointer-events: none;
  }

  .skip-link:focus-visible {
    position: fixed;
    transform: translateY(0);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 24%, transparent);
    outline: none;
    pointer-events: auto;
  }

  .page-shell {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 24px;
  }

  .section {
    padding: 96px 0;
  }

  .section-title {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    margin-bottom: 40px;
    text-align: center;
    color: var(--text);
  }

  .card {
    background: var(--bg-light);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
