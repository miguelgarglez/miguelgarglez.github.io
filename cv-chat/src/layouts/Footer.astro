---
const currentYear = new Date().getFullYear();
---

<footer id="footer">
    <div class="footer-content">
        <div class="footer-info">
            <p class="footer-kicker">/miguelgarglez</p>
            <h3>Miguel García</h3>
            <p>Software engineer</p>
        </div>

        <div class="footer-links">
            <a
                href="https://www.linkedin.com/in/miguel-garciag"
                target="_blank"
                rel="noreferrer">LinkedIn</a
            >
            <a
                href="https://x.com/miguel_garglez"
                target="_blank"
                rel="noreferrer">X (Twitter)</a
            >
        </div>

        <div class="footer-bottom">
            <p>
                &copy; {currentYear} Miguel García. Built with Astro and GSAP.
            </p>
        </div>
    </div>
</footer>

<style>
    #footer {
        background: var(--bg);
        color: var(--text);
        padding: 2.5rem 1.25rem 2rem;
        border-top: 1px solid var(--border);
    }

    .footer-content {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 1.5rem;
        align-items: end;
    }

    .footer-kicker {
        margin: 0 0 0.75rem;
        color: var(--primary);
        font-family: var(--font-mono, monospace);
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.04em;
    }

    .footer-info h3 {
        color: var(--text);
        margin: 0 0 0.45rem;
        font-size: clamp(1.25rem, 2vw, 1.65rem);
        font-weight: 500;
        letter-spacing: -0.02em;
    }

    .footer-info p {
        color: var(--text-muted);
        margin: 0;
        line-height: 1.5;
    }

    .footer-links {
        display: flex;
        gap: 1.5rem;
    }

    .footer-links a {
        color: var(--text-muted);
        font-family: var(--font-mono, monospace);
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        text-decoration: none;
        transition:
            color 160ms ease,
            transform 160ms var(--ease-out-quart);
        font-weight: 500;
    }

    @media (hover: hover) and (pointer: fine) {
        .footer-links a:hover {
            color: var(--primary);
            transform: translateY(-1px);
        }
    }

    .footer-links a:active {
        transform: scale(0.97);
    }

    .footer-links a:focus-visible {
        outline: none;
        color: var(--primary);
        box-shadow: 0 0 0 3px
            color-mix(in srgb, var(--primary) 22%, transparent);
        border-radius: 8px;
    }

    .footer-bottom {
        grid-column: 1 / -1;
        text-align: left;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border-muted);
        margin-top: 0.5rem;
    }

    .footer-bottom p {
        color: var(--text-muted);
        font-family: var(--font-mono, monospace);
        font-size: 0.72rem;
        letter-spacing: 0.02em;
        margin: 0;
    }

    @media (max-width: 768px) {
        #footer {
            padding: 2rem 1rem;
        }

        .footer-content {
            grid-template-columns: 1fr;
            text-align: left;
            gap: 1.5rem;
            align-items: start;
        }

        .footer-links {
            justify-content: flex-start;
            flex-wrap: wrap;
        }
    }
</style>
